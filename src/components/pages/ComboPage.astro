---
import { Icon } from 'astro-icon/components';
import { business, yearsInBusiness } from '../../data/business';
import { serviceTypes, getServiceBySlug } from '../../data/serviceTypes';
import { serviceAreas, getAreaBySlug, getNearbyAreas } from '../../data/serviceAreas';
import type { ServiceArea } from '../../data/serviceAreas';
import { serviceUrl, areaUrl, contactUrl } from '../../lib/urls';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SeoFaq from '../../components/SeoFaq.astro';

interface Props {
  serviceSlug: string;
  areaSlug: string;
  pageTitle: string;
  pageDescription: string;
}

const { serviceSlug, areaSlug, pageTitle, pageDescription } = Astro.props;
const service = getServiceBySlug(serviceSlug);
const area = getAreaBySlug(areaSlug);
const years = yearsInBusiness();
const nearbyAreas = area ? getNearbyAreas(areaSlug) : [];
const otherServices = service ? serviceTypes.filter(s => s.slug !== serviceSlug).slice(0, 4) : [];

const images = [
  { src: '/images/gallery/factory-workshop.webp', alt: 'Duct Masters manufacturing facility' },
  { src: '/images/gallery/laser-machine-operator.webp', alt: 'Precision CNC fabrication' },
];

if (!service || !area) Astro.response.status = 404;
---

{(!service || !area) ? (
  <BaseLayout title="Page Not Found" description="Not found.">
    <div class="mx-auto max-w-3xl px-5 py-20 text-center"><h1 class="font-display text-3xl">Page Not Found</h1><a href="/" class="mt-6 inline-flex items-center gap-2 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white">Return Home</a></div>
  </BaseLayout>
) : (
  <BaseLayout title={pageTitle} description={pageDescription}>
    <Breadcrumbs crumbs={[{ label: 'Services', href: '/services/' }, { label: service.name, href: serviceUrl(service.slug) }, { label: area.name }]} />

    {/* HERO */}
    <section class="relative overflow-hidden bg-gradient-to-br from-brand-900 to-brand-800">
      <div class="absolute inset-0"><img src={images[0].src} alt="" class="h-full w-full object-cover opacity-12" width="1200" height="670" loading="eager" /></div>
      <div class="relative mx-auto max-w-7xl px-5 py-16 lg:px-8 lg:py-20">
        <div class="flex items-center gap-3 text-accent-400"><Icon name={service.icon} class="size-8" /><span class="text-sm font-semibold uppercase tracking-wide">{service.name} in {area.name}</span></div>
        <h1 class="mt-3 font-display text-3xl text-white sm:text-4xl lg:text-5xl">{pageTitle}</h1>
        <p class="mt-4 max-w-3xl text-lg leading-relaxed text-brand-200">{pageDescription}</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href={business.phoneHref} class="inline-flex items-center gap-2 rounded-lg bg-brand-500 px-6 py-3 text-sm font-semibold text-white shadow hover:bg-brand-400"><Icon name="lucide:phone" class="size-4" />Call {business.phone}</a>
          <a href={business.whatsapp} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg bg-green-600 px-6 py-3 text-sm font-semibold text-white shadow hover:bg-green-500"><Icon name="lucide:message-circle" class="size-4" />WhatsApp</a>
          <a href={contactUrl()} class="inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur-sm hover:bg-white/20"><Icon name="lucide:file-text" class="size-4" />Request a Quote</a>
        </div>
      </div>
    </section>

    {/* CONTENT + IMAGE */}
    <section class="bg-white py-16 lg:py-20">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-5">
          <div class="lg:col-span-3">
            <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">{service.name} in {area.name}, Abu Dhabi</h2>
            <div class="mt-6 space-y-4 leading-relaxed text-stone-600">
              <p>{service.description}</p>
              <p>{area.description}</p>
              <p>At {business.name}, we have been a trusted provider of {service.name.toLowerCase()} to clients in {area.name} and the surrounding industrial zones for over {years} years. Based in M-40, Musaffah, our manufacturing facility is equipped with CNC laser cutters, press brakes, welding stations, and powder coating capabilities — allowing us to handle {service.name.toLowerCase()} projects of any scale with consistent quality and reliable delivery.</p>
              <p>We understand the specific requirements of industrial and commercial clients operating in {area.name}. Whether you need a single custom fabrication, a batch production run, or a full-scale supply contract, our team is ready to deliver to your specifications and schedule.</p>
              {nearbyAreas.length > 0 && <p>In addition to {area.name}, we also provide {service.name.toLowerCase()} to nearby locations including {nearbyAreas.map(a => a.name).join(', ')}.</p>}
            </div>
            <div class="mt-6 flex items-center gap-6 border-t border-stone-100 pt-6 text-sm text-stone-500">
              <span class="flex items-center gap-1.5"><Icon name="lucide:map-pin" class="size-4 text-brand-600" />{area.name}</span>
              <span class="flex items-center gap-1.5"><Icon name="lucide:shield-check" class="size-4 text-brand-600" />{business.license}</span>
            </div>
          </div>
          <div class="lg:col-span-2">
            <div class="relative overflow-hidden rounded-2xl shadow-lg"><img src={images[1].src} alt={images[1].alt} class="w-full object-cover" width="1200" height="670" loading="lazy" /></div>
            <p class="mt-3 text-center text-xs text-stone-400">{images[1].alt}</p>
          </div>
        </div>
      </div>
    </section>

    {/* PROCESS */}
    <section class="border-t border-stone-200/60 bg-gradient-to-b from-stone-50 to-white py-16 lg:py-20">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <h2 class="text-center font-display text-2xl text-brand-900 sm:text-3xl">Our {service.name} Process</h2>
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {service.process.map((step, i) => (
            <div class="rounded-2xl border border-stone-200 bg-white p-6 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all">
              <div class="flex size-10 items-center justify-center rounded-xl bg-brand-600 text-sm font-bold text-white">{i + 1}</div>
              <h3 class="mt-3 font-semibold text-brand-900">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-stone-600">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* NEARBY AREAS */}
    {nearbyAreas.length > 0 && (
      <section class="bg-stone-50 py-16 lg:py-20">
        <div class="mx-auto max-w-7xl px-5 lg:px-8">
          <h2 class="text-center font-display text-2xl text-brand-900 sm:text-3xl">Nearby Industrial Zones</h2>
          <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {nearbyAreas.map(n => (
              <a href={areaUrl(n.slug)} class="group rounded-xl border border-stone-200 bg-white p-5 transition-all hover:border-brand-200 hover:shadow-md hover:-translate-y-0.5"><p class="font-semibold text-stone-800 group-hover:text-brand-800">{n.name}</p><p class="mt-1 text-xs text-stone-500">{n.county}</p></a>
            ))}
          </div>
        </div>
      </section>
    )}

    <div class="border-t border-stone-200/60 bg-white"><SeoFaq service={service} area={area} /></div>

    {/* CTA */}
    <section class="relative overflow-hidden bg-gradient-to-b from-brand-900 to-brand-950">
      <div class="absolute inset-0"><img src={images[0].src} alt="" class="h-full w-full object-cover opacity-10" width="1200" height="670" loading="lazy" /></div>
      <div class="relative mx-auto max-w-4xl px-5 py-20 text-center lg:px-8">
        <h2 class="font-display text-3xl text-white sm:text-4xl">Get a Quote for {service.name} in {area.name}</h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-brand-200">Send us your project requirements. We provide competitive quotations with detailed pricing, production timelines, and delivery to {area.name}.</p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href={business.phoneHref} class="group inline-flex items-center gap-2 rounded-lg bg-brand-500 px-8 py-4 text-sm font-semibold text-white shadow-lg hover:bg-brand-400 hover:shadow-xl hover:scale-105"><Icon name="lucide:phone" class="size-5" />{business.phone}</a>
          <a href={business.whatsapp} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg bg-green-600 px-8 py-4 text-sm font-semibold text-white shadow-lg hover:bg-green-500 hover:shadow-xl hover:scale-105"><Icon name="lucide:message-circle" class="size-5" />WhatsApp</a>
          <a href={`mailto:${business.email}`} class="inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-8 py-4 text-sm font-semibold text-white backdrop-blur-sm hover:bg-white/20"><Icon name="lucide:mail" class="size-5" />{business.email}</a>
        </div>
      </div>
    </section>
  </BaseLayout>
)}