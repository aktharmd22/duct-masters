---
import { Icon } from 'astro-icon/components';
import { business, yearsInBusiness } from '../../data/business';
import { serviceTypes, getServiceBySlug } from '../../data/serviceTypes';
import { serviceAreas, getAreaBySlug, getNearbyAreas } from '../../data/serviceAreas';
import type { ServiceArea } from '../../data/serviceAreas';
import { serviceUrl, areaUrl, contactUrl } from '../../lib/urls';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeoFaq from '../../components/SeoFaq.astro';

interface Props {
  serviceSlug: string;
  areaSlug: string;
  pageTitle: string;
  pageDescription: string;
}

const { serviceSlug, areaSlug, pageTitle, pageDescription } = Astro.props;
const service = getServiceBySlug(serviceSlug);
const area = getAreaBySlug(areaSlug);
const years = yearsInBusiness();
const nearbyAreas = area ? getNearbyAreas(areaSlug) : [];
const otherServices = service ? serviceTypes.filter(s => s.slug !== serviceSlug).slice(0, 4) : [];

const images = [
  { src: '/images/gallery/factory-workshop.webp', alt: 'Duct Masters manufacturing facility' },
  { src: '/images/gallery/laser-machine-operator.webp', alt: 'Precision CNC fabrication' },
];

if (!service || !area) Astro.response.status = 404;
---

{(!service || !area) ? (
  <BaseLayout title="Page Not Found" description="Not found.">
    <div class="mx-auto max-w-3xl px-5 py-24 text-center"><h1 class="font-display text-4xl font-bold tracking-tight text-brand-900">Page Not Found</h1><a href="/" class="btn-shine mt-8 inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-accent-500 to-brand-500 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-accent-600/30">Return Home</a></div>
  </BaseLayout>
) : (
  <BaseLayout title={pageTitle} description={pageDescription}>

    {/* HERO */}
    <section class="relative overflow-hidden bg-brand-950">
      <div class="absolute inset-0">
        <img src={images[0].src} alt="" class="h-full w-full object-cover opacity-20" width="1200" height="670" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-br from-brand-950 via-brand-950/85 to-brand-950/50"></div>
        <div class="blueprint-grid-dark absolute inset-0 opacity-60"></div>
        <div class="absolute -top-24 right-0 h-96 w-96 rounded-full bg-accent-500/15 blur-[120px] animate-glow"></div>
      </div>
      <div class="relative mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-28">
        <div data-reveal class="inline-flex items-center gap-2.5 rounded-full border border-accent-400/20 bg-white/5 px-4 py-1.5 text-accent-400 backdrop-blur-sm"><Icon name={service.icon} class="size-5" /><span class="text-sm font-semibold uppercase tracking-wide">{service.name} in {area.name}</span></div>
        <h1 data-reveal style="--reveal-delay: 80ms" class="mt-5 max-w-4xl font-display text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">{pageTitle}</h1>
        <p data-reveal style="--reveal-delay: 160ms" class="mt-6 max-w-3xl text-lg leading-relaxed text-brand-200">{pageDescription}</p>
        <div data-reveal style="--reveal-delay: 240ms" class="mt-9 flex flex-wrap gap-4">
          <a href={business.phoneHref} class="btn-shine group inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-accent-500 to-brand-500 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-accent-600/30 transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-accent-600/50"><Icon name="lucide:phone" class="size-4 transition-transform group-hover:rotate-12" />Call {business.phone}</a>
          <a href={business.whatsapp} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-xl bg-green-600 px-6 py-3.5 text-sm font-semibold text-white shadow transition-all hover:-translate-y-0.5 hover:bg-green-500"><Icon name="lucide:message-circle" class="size-4" />WhatsApp</a>
          <a href={contactUrl()} class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 px-6 py-3.5 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:border-white/30 hover:bg-white/10"><Icon name="lucide:file-text" class="size-4" />Request a Quote</a>
        </div>
      </div>
    </section>

    {/* CONTENT + IMAGE */}
    <section class="bg-white py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-5 lg:gap-16">
          <div data-reveal="left" class="lg:col-span-3">
            <h2 class="font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">{service.name} in {area.name}, Abu Dhabi</h2>
            <div class="mt-6 space-y-4 leading-relaxed text-stone-600">
              <p>{service.description}</p>
              <p>{area.description}</p>
              <p>At {business.name}, we have been a trusted provider of {service.name.toLowerCase()} to clients in {area.name} and the surrounding industrial zones for over {years} years. Based in M-40, Musaffah, our manufacturing facility is equipped with CNC laser cutters, press brakes, welding stations, and powder coating capabilities — allowing us to handle {service.name.toLowerCase()} projects of any scale with consistent quality and reliable delivery.</p>
              <p>We understand the specific requirements of industrial and commercial clients operating in {area.name}. Whether you need a single custom fabrication, a batch production run, or a full-scale supply contract, our team is ready to deliver to your specifications and schedule.</p>
              {nearbyAreas.length > 0 && <p>In addition to {area.name}, we also provide {service.name.toLowerCase()} to nearby locations including {nearbyAreas.map(a => a.name).join(', ')}.</p>}
            </div>
            <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3 border-t border-stone-100 pt-6 text-sm font-medium text-stone-600">
              <span class="flex items-center gap-2"><Icon name="lucide:map-pin" class="size-4 text-brand-600" />{area.name}</span>
              <span class="flex items-center gap-2"><Icon name="lucide:shield-check" class="size-4 text-brand-600" />{business.license}</span>
            </div>
          </div>
          <div data-reveal="right" class="lg:col-span-2">
            <div class="relative overflow-hidden rounded-3xl shadow-2xl shadow-brand-900/20 ring-1 ring-stone-900/5"><img src={images[1].src} alt={images[1].alt} class="w-full object-cover" width="1200" height="670" loading="lazy" /><div class="absolute inset-0 bg-gradient-to-t from-brand-950/25 to-transparent"></div></div>
            <p class="mt-3 text-center text-xs text-stone-400">{images[1].alt}</p>
          </div>
        </div>
      </div>
    </section>

    {/* PROCESS */}
    <section class="relative overflow-hidden border-t border-stone-200/60 bg-stone-50 py-20 lg:py-28">
      <div class="dot-grid absolute inset-0 opacity-40"></div>
      <div class="relative mx-auto max-w-7xl px-5 lg:px-8">
        <h2 data-reveal class="text-center font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">Our {service.name} Process</h2>
        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {service.process.map((step, i) => (
            <div data-reveal style={`--reveal-delay: ${i * 90}ms`} class="group rounded-3xl border border-stone-200 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-brand-900/10">
              <div class="flex size-12 items-center justify-center rounded-2xl bg-gradient-to-br from-accent-500 to-brand-500 font-display text-lg font-bold text-white shadow-lg shadow-accent-600/25 transition-transform group-hover:scale-110">{i + 1}</div>
              <h3 class="mt-4 font-semibold text-brand-900">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-stone-600">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* NEARBY AREAS */}
    {nearbyAreas.length > 0 && (
      <section class="bg-white py-20 lg:py-28">
        <div class="mx-auto max-w-7xl px-5 lg:px-8">
          <h2 data-reveal class="text-center font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">Nearby Industrial Zones</h2>
          <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {nearbyAreas.map((n, i) => (
              <a href={areaUrl(n.slug)} data-reveal style={`--reveal-delay: ${(i % 4) * 80}ms`} class="group flex items-center gap-4 rounded-2xl border border-stone-200 bg-stone-50 p-5 transition-all duration-300 hover:-translate-y-1 hover:border-brand-300 hover:bg-white hover:shadow-lg hover:shadow-brand-900/5"><div class="flex size-11 shrink-0 items-center justify-center rounded-xl bg-brand-50 ring-1 ring-brand-100 transition-colors group-hover:bg-brand-500 group-hover:ring-brand-500"><Icon name="lucide:map-pin" class="size-5 text-brand-600 transition-colors group-hover:text-white" /></div><div><p class="font-semibold text-stone-800 group-hover:text-brand-800">{n.name}</p><p class="mt-1 text-xs text-stone-500">{n.county}</p></div></a>
            ))}
          </div>
        </div>
      </section>
    )}

    <div class="border-t border-stone-200/60 bg-white"><SeoFaq service={service} area={area} /></div>

    {/* CTA */}
    <section class="relative overflow-hidden bg-brand-950">
      <div class="absolute inset-0">
        <img src={images[0].src} alt="" class="h-full w-full object-cover opacity-15" width="1200" height="670" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-brand-950 via-brand-950/90 to-brand-900/80"></div>
        <div class="blueprint-grid-dark absolute inset-0 opacity-70"></div>
        <div class="absolute -bottom-24 left-1/2 h-80 w-[42rem] -translate-x-1/2 rounded-full bg-accent-500/15 blur-[120px]"></div>
      </div>
      <div class="relative mx-auto max-w-4xl px-5 py-24 text-center lg:px-8">
        <h2 data-reveal class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">Get a Quote for {service.name} in {area.name}</h2>
        <p data-reveal style="--reveal-delay: 80ms" class="mx-auto mt-5 max-w-2xl text-lg text-brand-200">Send us your project requirements. We provide competitive quotations with detailed pricing, production timelines, and delivery to {area.name}.</p>
        <div data-reveal style="--reveal-delay: 160ms" class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href={business.phoneHref} class="btn-shine group inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-accent-500 to-brand-500 px-8 py-4 text-sm font-semibold text-white shadow-lg shadow-accent-600/30 transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-accent-600/50"><Icon name="lucide:phone" class="size-5 transition-transform group-hover:rotate-12" />{business.phone}</a>
          <a href={business.whatsapp} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-xl bg-green-600 px-8 py-4 text-sm font-semibold text-white shadow-lg transition-all hover:-translate-y-0.5 hover:bg-green-500"><Icon name="lucide:message-circle" class="size-5" />WhatsApp</a>
          <a href={`mailto:${business.email}`} class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 px-8 py-4 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:border-white/30 hover:bg-white/10"><Icon name="lucide:mail" class="size-5" />{business.email}</a>
        </div>
      </div>
    </section>
  </BaseLayout>
)}
