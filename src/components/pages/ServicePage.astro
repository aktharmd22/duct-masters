---
import { Icon } from 'astro-icon/components';
import { business, yearsInBusiness } from '../../data/business';
import { serviceTypes, getServiceBySlug } from '../../data/serviceTypes';
import { serviceUrl, contactUrl } from '../../lib/urls';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeoFaq from '../../components/SeoFaq.astro';

interface Props {
  serviceSlug: string;
  pageTitle: string;
  pageDescription: string;
}

const { serviceSlug, pageTitle, pageDescription } = Astro.props;
const service = getServiceBySlug(serviceSlug);
const years = yearsInBusiness();

const industriesList = [
  { name: 'HVAC Contractors', icon: 'lucide:air-vent', desc: 'Ductwork and ventilation system fabrication' },
  { name: 'MEP Contractors', icon: 'lucide:cog', desc: 'Coordinated mechanical & plumbing projects' },
  { name: 'Construction Companies', icon: 'lucide:building-2', desc: 'Commercial & infrastructure builds' },
  { name: 'Industrial Facilities', icon: 'lucide:factory', desc: 'Process ventilation & heavy fabrication' },
  { name: 'Commercial Buildings', icon: 'lucide:building', desc: 'Hotels, offices, hospitals, retail' },
  { name: 'Infrastructure Projects', icon: 'lucide:landmark', desc: 'Airports, metro, public works' },
];

// Pick 4 images for this service page — rotate based on service index
const serviceIdx = serviceTypes.indexOf(service);
const images = [
  { src: '/images/gallery/factory-workshop.webp', alt: 'Duct Masters manufacturing facility in Musaffah' },
  { src: '/images/gallery/laser-machine-operator.webp', alt: 'CNC laser cutting precision fabrication' },
  { src: '/images/gallery/workers-fabricating-sheet-metal-….webp', alt: 'Sheet metal fabrication in progress' },
  { src: '/images/gallery/technician-inspecting-hvac-duct-….webp', alt: 'Quality inspection of HVAC ductwork' },
  { src: '/images/gallery/engineers-reviewing-drawings-in-….webp', alt: 'Engineering review of fabrication drawings' },
  { src: '/images/gallery/workers-collaborating-on-metal-f….webp', alt: 'Fabrication team at work' },
  { src: '/images/gallery/preparing-components.webp', alt: 'Preparing metal components for fabrication' },
  { src: '/images/gallery/logo-on-uniform.webp', alt: 'Duct Masters factory team' },
];

if (!service) Astro.response.status = 404;
---

{!service ? (
  <BaseLayout title="Page Not Found" description="The requested page could not be found.">
    <div class="mx-auto max-w-3xl px-5 py-24 text-center">
      <h1 class="font-display text-4xl font-bold tracking-tight text-brand-900">Page Not Found</h1>
      <a href="/" class="btn-shine mt-8 inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-accent-500 to-brand-500 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-accent-600/30">Return Home</a>
    </div>
  </BaseLayout>
) : (
  <BaseLayout title={pageTitle} description={pageDescription}>

    {/* ===== HERO ===== */}
    <section class="relative overflow-hidden bg-brand-950">
      <div class="absolute inset-0">
        <img src={images[0].src} alt="" class="h-full w-full object-cover opacity-20" width="1200" height="670" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-br from-brand-950 via-brand-950/85 to-brand-950/50"></div>
        <div class="blueprint-grid-dark absolute inset-0 opacity-60"></div>
        <div class="absolute -top-24 right-0 h-96 w-96 rounded-full bg-accent-500/15 blur-[120px] animate-glow"></div>
      </div>
      <div class="relative mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-28">
        <div data-reveal class="inline-flex items-center gap-2.5 rounded-full border border-accent-400/20 bg-white/5 px-4 py-1.5 text-accent-400 backdrop-blur-sm">
          <Icon name={service.icon} class="size-5" />
          <span class="text-sm font-semibold uppercase tracking-wide">{service.name}</span>
        </div>
        <h1 data-reveal style="--reveal-delay: 80ms" class="mt-5 max-w-4xl font-display text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">{pageTitle}</h1>
        <p data-reveal style="--reveal-delay: 160ms" class="mt-6 max-w-3xl text-lg leading-relaxed text-brand-200">{service.description}</p>
        <div data-reveal style="--reveal-delay: 240ms" class="mt-9 flex flex-wrap gap-4">
          <a href={business.phoneHref} class="btn-shine group inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-accent-500 to-brand-500 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-accent-600/30 transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-accent-600/50">
            <Icon name="lucide:phone" class="size-4 transition-transform group-hover:rotate-12" />Call {business.phone}
          </a>
          <a href={business.whatsapp} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-xl bg-green-600 px-6 py-3.5 text-sm font-semibold text-white shadow transition-all hover:-translate-y-0.5 hover:bg-green-500">
            <Icon name="lucide:message-circle" class="size-4" />WhatsApp
          </a>
          <a href={contactUrl()} class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 px-6 py-3.5 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:border-white/30 hover:bg-white/10">
            <Icon name="lucide:file-text" class="size-4" />Request a Quote
          </a>
        </div>
      </div>
    </section>

    {/* ===== WHAT IS + IMAGE ===== */}
    <section class="bg-white py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-5 lg:gap-16">
          <div data-reveal="left" class="lg:col-span-3">
            <h2 class="font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">Expert {service.name} in Abu Dhabi</h2>
            <div class="mt-6 space-y-4 leading-relaxed text-stone-600">
              <p>{service.description}</p>
              <p>At {business.name}, we have built our reputation on delivering high-quality {service.name.toLowerCase()} from our manufacturing facility in M-40, Musaffah — the industrial heart of Abu Dhabi. With {years}+ years of experience serving contractors, MEP consultants, construction firms, and industrial clients across the UAE, we understand the specific requirements of every project type.</p>
              <p>Our team combines skilled craftsmanship with modern CNC machinery — including fiber laser cutters, CNC press brakes, shearing machines, rolling equipment, and professional welding stations. We work with galvanized iron (GI), stainless steel, aluminum, and mild steel in gauges from 0.5mm to 6mm and beyond, ensuring every component meets SMACNA standards and project specifications.</p>
              <p>Whether your project requires a single custom part, a batch production run, or a full-scale supply contract for a large commercial development, our facility is equipped to handle your {service.name.toLowerCase()} requirements with the quality, precision, and reliability you expect.</p>
            </div>
            <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3 border-t border-stone-100 pt-6 text-sm font-medium text-stone-600">
              <span class="flex items-center gap-2"><Icon name="lucide:shield-check" class="size-4 text-brand-600" />{business.license}</span>
              <span class="flex items-center gap-2"><Icon name="lucide:map-pin" class="size-4 text-brand-600" />{business.address.street}</span>
              <span class="flex items-center gap-2"><Icon name="lucide:ruler" class="size-4 text-brand-600" />SMACNA Standards</span>
            </div>
          </div>
          <div data-reveal="right" class="lg:col-span-2">
            <div class="relative overflow-hidden rounded-3xl shadow-2xl shadow-brand-900/20 ring-1 ring-stone-900/5">
              <img src={images[1].src} alt={images[1].alt} class="w-full object-cover" width="1200" height="670" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-950/25 to-transparent"></div>
            </div>
            <p class="mt-3 text-center text-xs text-stone-400">{images[1].alt}</p>
          </div>
        </div>
      </div>
    </section>

    {/* ===== OUR PROCESS ===== */}
    <section class="relative overflow-hidden border-t border-stone-200/60 bg-stone-50 py-20 lg:py-28">
      <div class="dot-grid absolute inset-0 opacity-40"></div>
      <div class="relative mx-auto max-w-7xl px-5 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span data-reveal class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-white px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-700 shadow-sm">
            <Icon name="lucide:list-checks" class="size-3.5" /><span class="bilingual" data-lang-en="Our Process" data-lang-ar="منهجية العمل">Our Process</span>
          </span>
          <h2 data-reveal style="--reveal-delay: 80ms" class="mt-5 font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">How We Deliver {service.name}</h2>
          <p data-reveal style="--reveal-delay: 140ms" class="mx-auto mt-4 max-w-2xl text-stone-600">Every {service.name.toLowerCase()} project follows a structured, quality-controlled manufacturing process to ensure accuracy, consistency, and on-time delivery — from your initial inquiry to the final dispatch.</p>
        </div>
        <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
          {service.process.map((step, index) => (
            <div data-reveal style={`--reveal-delay: ${index * 90}ms`} class="group relative rounded-3xl border border-stone-200 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-brand-900/10">
              <div class="flex size-12 items-center justify-center rounded-2xl bg-gradient-to-br from-accent-500 to-brand-500 font-display text-lg font-bold text-white shadow-lg shadow-accent-600/25 transition-transform group-hover:scale-110">{index + 1}</div>
              <h3 class="mt-4 font-semibold text-brand-900">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-stone-600">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ===== WHO NEEDS THIS + IMAGE ===== */}
    <section class="relative overflow-hidden bg-brand-950 py-20 lg:py-28">
      <div class="blueprint-grid-dark absolute inset-0"></div>
      <div class="absolute -bottom-24 left-0 h-96 w-96 rounded-full bg-brand-500/15 blur-[120px]"></div>
      <div class="relative mx-auto max-w-7xl px-5 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-5 lg:gap-16">
          <div data-reveal="left" class="lg:col-span-3">
            <span class="inline-flex items-center gap-2 rounded-full border border-accent-400/20 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-accent-400">
              <Icon name="lucide:building-2" class="size-3.5" /><span class="bilingual" data-lang-en="Industries Served" data-lang-ar="القطاعات التي نخدمها">Industries Served</span>
            </span>
            <h2 class="mt-5 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">Who Needs {service.name}?</h2>
            <p class="mt-4 text-brand-300">{service.name} is a critical requirement across multiple sectors in the UAE. Our clients range from HVAC and MEP contractors managing large-scale commercial projects to industrial facility operators requiring process ventilation and custom metal fabrications.</p>
            <div class="mt-8 grid gap-3 sm:grid-cols-2">
              {industriesList.map((ind, i) => (
                <div data-reveal style={`--reveal-delay: ${i * 70}ms`} class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.03] p-4 backdrop-blur-sm transition-colors hover:border-accent-400/30 hover:bg-white/[0.06]">
                  <div class="flex size-10 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-accent-500/20 to-brand-500/10 ring-1 ring-white/10">
                    <Icon name={ind.icon} class="size-4 text-accent-400" />
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-white">{ind.name}</p>
                    <p class="text-xs text-brand-300">{ind.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div data-reveal="right" class="lg:col-span-2">
            <div class="relative overflow-hidden rounded-3xl shadow-2xl shadow-brand-950/50 ring-1 ring-white/10">
              <img src={images[2].src} alt={images[2].alt} class="w-full object-cover" width="1200" height="670" loading="lazy" />
            </div>
            <p class="mt-3 text-center text-xs text-brand-300">{images[2].alt}</p>
          </div>
        </div>
      </div>
    </section>

    {/* ===== WHY CHOOSE US ===== */}
    <section class="bg-white py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span data-reveal class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-700">
            <Icon name="lucide:award" class="size-3.5" /><span class="bilingual" data-lang-en="Why Duct Masters" data-lang-ar="لماذا دكت ماسترز">Why Duct Masters</span>
          </span>
          <h2 data-reveal style="--reveal-delay: 80ms" class="mt-5 font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">Why Leading Contractors Choose {business.name}</h2>
          <p data-reveal style="--reveal-delay: 140ms" class="mx-auto mt-4 max-w-2xl text-stone-600">Established in {business.yearEstablished}, we bring {years}+ years of UAE manufacturing experience, modern CNC-equipped facilities, and an unwavering commitment to quality — here is why project managers and procurement teams trust us with their {service.name.toLowerCase()} requirements.</p>
        </div>
        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {[
            { icon: 'lucide:shield-check', title: 'UAE Trade Licensed Manufacturer', desc: `${business.legalName} — legally registered and licensed for air conditioner requisites manufacturing. Full compliance with UAE commercial and industrial regulations.` },
            { icon: 'lucide:map-pin', title: 'Central Musaffah Location', desc: `Our facility at ${business.address.street} places us at the center of Abu Dhabi's industrial zone — minimizing delivery distances and logistics costs for your projects.` },
            { icon: 'lucide:cpu', title: 'CNC-Equipped Facility', desc: 'Fiber laser cutter, CNC press brakes, plasma cutting, shearing, rolling, and welding stations — all under one roof for end-to-end fabrication without subcontracting.' },
            { icon: 'lucide:users', title: 'Experienced Fabrication Team', desc: `Our workforce includes certified welders, CNC operators, and quality inspectors with years of hands-on experience in HVAC duct fabrication and metal works.` },
            { icon: 'lucide:clipboard-check', title: 'Documented Quality Control', desc: 'Every order undergoes dimensional inspection and QC verification. We provide material certificates, inspection reports, and project documentation as required.' },
            { icon: 'lucide:truck', title: 'Reliable Project Delivery', desc: 'We deliver to project sites across Abu Dhabi, Al Ain, the Western Region, and throughout the UAE. Our logistics are planned around your project schedule.' },
            { icon: 'lucide:file-text', title: 'Shop Drawings & Engineering', desc: 'Our team can prepare fabrication shop drawings from your design intent, or work directly from your approved drawings — whichever your project requires.' },
            { icon: 'lucide:badge-check', title: 'SMACNA & Project Standards', desc: 'Ductwork fabricated to SMACNA standards. We adapt to project-specific specifications, material requirements, and quality benchmarks.' },
          ].map((item, i) => (
            <div data-reveal style={`--reveal-delay: ${(i % 4) * 80}ms`} class="group gradient-border rounded-3xl border border-stone-200 bg-stone-50 p-6 transition-all duration-500 hover:-translate-y-1.5 hover:bg-white hover:shadow-xl hover:shadow-brand-900/10">
              <div class="flex size-12 items-center justify-center rounded-2xl bg-gradient-to-br from-accent-500/15 to-brand-500/10 ring-1 ring-brand-100 transition-transform group-hover:scale-110"><Icon name={item.icon} class="size-6 text-brand-600" /></div>
              <h3 class="mt-4 font-semibold text-brand-900">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-stone-600">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ===== FACILITY IMAGE STRIP ===== */}
    <section class="overflow-hidden bg-stone-50 py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <h2 data-reveal class="text-center font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">Our Facility &amp; Capabilities</h2>
        <p data-reveal style="--reveal-delay: 80ms" class="mx-auto mt-4 max-w-2xl text-center text-stone-600">Take a look inside our Musaffah manufacturing facility — where precision, quality, and reliability come together.</p>
      </div>
      <div data-reveal class="mt-12 flex gap-5 overflow-x-auto px-5 pb-6 lg:px-8 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        <div class="mx-auto flex max-w-7xl gap-5">
          {images.slice(0, 4).map((img, i) => (
            <div class="group relative w-64 shrink-0 overflow-hidden rounded-3xl shadow-lg ring-1 ring-stone-900/5 sm:w-72 lg:w-80">
              <img src={img.src} alt={img.alt} class="h-48 w-full object-cover transition-transform duration-700 group-hover:scale-110 sm:h-56" width="1200" height="670" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-950/70 via-transparent to-transparent opacity-0 transition-opacity group-hover:opacity-100">
                <p class="absolute bottom-4 left-4 right-4 text-xs text-white/90">{img.alt}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ===== RELATED SERVICES ===== */}
    {service.relatedServices.length > 0 && (
      <section class="bg-white py-20 lg:py-28">
        <div class="mx-auto max-w-7xl px-5 lg:px-8">
          <h2 data-reveal class="bilingual text-center font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl" data-lang-en="Complementary Fabrication Services" data-lang-ar="خدمات التشكيل المكملة">Complementary Fabrication Services</h2>
          <p data-reveal style="--reveal-delay: 80ms" class="mx-auto mt-4 max-w-2xl text-center text-stone-600">Our {service.name.toLowerCase()} is part of a complete range of metal fabrication services — explore related capabilities available from the same Musaffah facility.</p>
          <div data-reveal class="mt-10 flex flex-wrap justify-center gap-3">
            {service.relatedServices.map((relatedSlug) => {
              const related = getServiceBySlug(relatedSlug);
              if (!related) return null;
              return (
                <a href={serviceUrl(related.slug)} class="group inline-flex items-center gap-2 rounded-full border border-stone-200 bg-white px-5 py-2.5 text-sm font-medium text-stone-600 shadow-sm transition-all hover:-translate-y-0.5 hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700 hover:shadow">
                  <Icon name={related.icon} class="size-4 text-brand-500" />{related.name}
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    {/* ===== FAQ ===== */}
    <div class="border-t border-stone-200/60 bg-white">
      <SeoFaq service={service} />
    </div>

    {/* ===== FINAL CTA ===== */}
    <section class="relative overflow-hidden bg-brand-950">
      <div class="absolute inset-0">
        <img src={images[3].src} alt="" class="h-full w-full object-cover opacity-15" width="1200" height="670" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-brand-950 via-brand-950/90 to-brand-900/80"></div>
        <div class="blueprint-grid-dark absolute inset-0 opacity-70"></div>
        <div class="absolute -bottom-24 left-1/2 h-80 w-[42rem] -translate-x-1/2 rounded-full bg-accent-500/15 blur-[120px]"></div>
      </div>
      <div class="relative mx-auto max-w-4xl px-5 py-24 text-center lg:px-8">
        <h2 data-reveal class="bilingual font-display text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl" data-lang-en="Get a Competitive Quotation for {service.name}" data-lang-ar="احصل على عرض سعر تنافسي لـ {service.name}">Get a Competitive Quotation for {service.name}</h2>
        <p data-reveal style="--reveal-delay: 80ms" class="mx-auto mt-5 max-w-2xl text-lg text-brand-200">Send us your drawings, specifications, and quantities. Our team will provide a detailed quotation with pricing breakdown, production timeline, and delivery schedule — typically within one business day.</p>
        <div data-reveal style="--reveal-delay: 160ms" class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href={business.phoneHref} class="btn-shine group inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-accent-500 to-brand-500 px-8 py-4 text-sm font-semibold text-white shadow-lg shadow-accent-600/30 transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-accent-600/50">
            <Icon name="lucide:phone" class="size-5 transition-transform group-hover:rotate-12" />{business.phone}
          </a>
          <a href={business.whatsapp} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-xl bg-green-600 px-8 py-4 text-sm font-semibold text-white shadow-lg transition-all hover:-translate-y-0.5 hover:bg-green-500">
            <Icon name="lucide:message-circle" class="size-5" />WhatsApp
          </a>
          <a href={`mailto:${business.email}`} class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 px-8 py-4 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:border-white/30 hover:bg-white/10">
            <Icon name="lucide:mail" class="size-5" />{business.email}
          </a>
        </div>
        <p class="mt-6 text-xs text-brand-300">Or visit our facility: {business.address.street}, {business.address.city}, {business.address.country}</p>
      </div>
    </section>
  </BaseLayout>
)}
