---
import type { ServiceArea } from '../data/serviceAreas';
import type { ServiceType } from '../data/serviceTypes';
import { getReviewsForPage, reviews } from '../data/seoContent';
import { Icon } from 'astro-icon/components';
import { business } from '../data/business';

interface Props {
  area?: ServiceArea;
  service?: ServiceType;
}

const { area, service } = Astro.props;

const pageReviews = getReviewsForPage(service?.slug, area?.slug, 3);

const avgRating = reviews.length > 0
  ? reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length
  : 0;

const aggregateSchema = reviews.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'HVACBusiness',
  name: business.name,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: avgRating.toFixed(1),
    bestRating: '5',
    worstRating: '1',
    reviewCount: reviews.length,
  },
  review: pageReviews.map((r) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: r.author },
    datePublished: r.date,
    reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: 5 },
    reviewBody: r.text,
  })),
} : null;

function formatDate(iso: string): string {
  const date = new Date(iso + 'T00:00:00');
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

{pageReviews.length > 0 && (
  <section class="mt-16">
    <h2 data-reveal class="font-display text-2xl font-bold tracking-tight text-stone-900">What Our Clients Say</h2>

    <div data-reveal style="--reveal-delay: 80ms" class="mt-4 flex items-center gap-2">
      <div class="flex items-center gap-0.5">
        {Array.from({ length: 5 }).map((_, i) => (
          <Icon
            name="lucide:star"
            class:list={[
              'size-5',
              i < Math.round(avgRating)
                ? 'fill-accent-400 text-accent-400'
                : 'fill-stone-200 text-stone-200',
            ]}
          />
        ))}
      </div>
      <span class="text-sm font-semibold text-stone-800">
        {avgRating.toFixed(1)} out of 5
      </span>
      <span class="text-sm text-stone-500">
        based on {reviews.length} reviews
      </span>
    </div>

    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {pageReviews.map((review, index) => {
        const fullStars = Math.floor(review.rating);
        return (
          <div
            data-reveal
            style={`--reveal-delay: ${(index % 3) * 90}ms`}
            class="group relative overflow-hidden rounded-3xl border border-stone-200 bg-gradient-to-br from-white to-stone-50 p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-brand-900/5"
          >
            <Icon name="lucide:quote" class="pointer-events-none absolute -top-1 right-4 size-14 text-accent-400/10" />
            <div class="relative flex items-center gap-0.5">
              {Array.from({ length: 5 }).map((_, i) => (
                <Icon
                  name="lucide:star"
                  class:list={[
                    'size-4',
                    i < fullStars
                      ? 'fill-accent-400 text-accent-400'
                      : 'fill-stone-200 text-stone-200',
                  ]}
                />
              ))}
            </div>

            <p class="relative mt-3 text-sm leading-relaxed text-stone-600">
              {review.text}
            </p>

            <div class="relative mt-4 border-t border-stone-100 pt-3">
              <span class="text-sm font-semibold text-stone-800">
                {review.author}
              </span>
              <span class="block text-xs text-stone-400">
                {formatDate(review.date)}
              </span>
            </div>
          </div>
        );
      })}
    </div>
  </section>
)}

{aggregateSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(aggregateSchema)} />
)}
