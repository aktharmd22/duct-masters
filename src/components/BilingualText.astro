---
// Bilingual content block — renders both English and Arabic
// The client-side language toggle shows/hides based on selected language
interface Props {
  en: string;
  ar: string;
  /** HTML tag to wrap content in */
  tag?: 'span' | 'p' | 'h1' | 'h2' | 'h3' | 'div' | 'li';
  class?: string;
}

const { en, ar, tag = 'span', class: className = '' } = Astro.props;
const Tag = tag;
---

<Tag class={`bilingual ${className}`} data-lang-en={en} data-lang-ar={ar}>{en}</Tag>

<script is:inline>
  // Bilingual content switcher — runs once on page load and on language toggle
  function switchBilingualContent(lang) {
    document.querySelectorAll('.bilingual').forEach(el => {
      const text = el.getAttribute('data-lang-' + lang);
      if (text) el.textContent = text;
    });
    // Also handle placeholder attributes
    document.querySelectorAll('[data-lang-placeholder-en]').forEach(el => {
      const ph = el.getAttribute('data-lang-placeholder-' + lang);
      if (ph) el.setAttribute('placeholder', ph);
    });
  }

  // Listen for language change events from LanguageToggle
  document.addEventListener('langChanged', (e) => {
    switchBilingualContent(e.detail.lang);
  });

  // Apply on load if Arabic is saved
  try {
    const saved = localStorage.getItem('ductmasters-lang');
    if (saved === 'ar') switchBilingualContent('ar');
  } catch {}
</script>
