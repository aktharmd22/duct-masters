---
import { Icon } from 'astro-icon/components';
import type { ServiceArea } from '../data/serviceAreas';
import type { ServiceType } from '../data/serviceTypes';
import { generateFaqs } from '../data/seoContent';

interface Props {
  area?: ServiceArea;
  service?: ServiceType;
}

const { area, service } = Astro.props;

const faqs = generateFaqs(
  service?.slug,
  area?.name,
);

const heading = service && area
  ? `Frequently Asked Questions about ${service.name} in ${area.name}`
  : service
  ? `Frequently Asked Questions about ${service.name}`
  : area
  ? `Frequently Asked Questions about Fabrication Services in ${area.name}`
  : 'Frequently Asked Questions';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<section class="mx-auto max-w-3xl px-5 py-20 lg:px-8 lg:py-24">
  <div data-reveal class="flex items-center gap-4">
    <span class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-accent-500/15 to-brand-500/10 ring-1 ring-brand-100">
      <Icon name="lucide:help-circle" class="size-6 text-brand-600" />
    </span>
    <h2 class="font-display text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">
      {heading}
    </h2>
  </div>

  <div class="mt-10 space-y-3">
    {faqs.map((faq, i) => (
      <details data-reveal style={`--reveal-delay: ${Math.min(i, 6) * 60}ms`} class="group rounded-2xl border border-stone-200 bg-white shadow-sm transition-all duration-300 open:border-brand-200 open:shadow-md hover:border-brand-200">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 text-base font-semibold text-stone-800 transition-colors group-open:text-brand-700 [&::-webkit-details-marker]:hidden [&::marker]:hidden">
          <span>{faq.question}</span>
          <span class="flex size-8 shrink-0 items-center justify-center rounded-full bg-stone-100 text-stone-500 transition-all duration-300 group-open:bg-brand-500 group-open:text-white group-open:rotate-180">
            <Icon name="lucide:chevron-down" class="size-5" />
          </span>
        </summary>
        <div class="border-t border-stone-100 px-6 py-5 text-sm leading-relaxed text-stone-600">
          {faq.answer}
        </div>
      </details>
    ))}
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
