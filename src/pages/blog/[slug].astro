---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogUrl, contactUrl } from '../../lib/urls';
import { business } from '../../data/business';
import { Icon } from 'astro-icon/components';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const categoryColors: Record<string, { bg: string; text: string }> = {
  industry: { bg: 'bg-brand-100', text: 'text-brand-700' },
  guides: { bg: 'bg-accent-100', text: 'text-accent-700' },
  projects: { bg: 'bg-stone-200', text: 'text-stone-700' },
  news: { bg: 'bg-stone-100', text: 'text-stone-600' },
};

const colors = categoryColors[post.data.category] || categoryColors.news;

function formatDate(iso: string): string {
  const date = new Date(iso + 'T00:00:00');
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishDate,
  author: {
    '@type': 'Organization',
    name: post.data.author,
    url: business.website,
  },
  publisher: {
    '@type': 'Organization',
    name: business.name,
    url: business.website,
    telephone: business.phone,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${business.website}${blogUrl(post.id)}`,
  },
};
---

<BaseLayout
  title={`${post.data.title} | ${business.name}`}
  description={post.data.description}
  canonicalUrl={`${business.website}${blogUrl(post.id)}`}
  schema={schema}
>

  <article>
    <header class="relative overflow-hidden bg-brand-950">
      <div class="blueprint-grid-dark animate-grid-pan absolute inset-0 opacity-70"></div>
      <div class="absolute -top-24 right-0 h-[32rem] w-[32rem] rounded-full bg-accent-500/20 blur-[120px] animate-glow"></div>
      <div class="absolute bottom-0 left-1/4 h-72 w-72 rounded-full bg-brand-500/20 blur-[100px] animate-float-slow"></div>
      <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-brand-950 to-transparent"></div>

      <div class="relative mx-auto max-w-3xl px-5 py-16 lg:px-8 lg:py-24">
        <div data-reveal class="flex flex-wrap items-center gap-3">
          <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-semibold capitalize ${colors.bg} ${colors.text}`}>
            {post.data.category}
          </span>
          {post.data.readingTime && (
            <span class="flex items-center gap-1 text-xs text-brand-200">
              <Icon name="lucide:clock" class="size-3" />
              {post.data.readingTime}
            </span>
          )}
        </div>

        <h1 data-reveal style="--reveal-delay: 80ms" class="mt-6 font-display text-4xl font-bold leading-[1.1] tracking-tight text-white sm:text-5xl">
          {post.data.title}
        </h1>

        <div data-reveal style="--reveal-delay: 160ms" class="mt-6 flex items-center gap-3 text-sm text-brand-200">
          <div class="flex items-center gap-1.5">
            <Icon name="lucide:calendar" class="size-4 text-accent-400" />
            <time datetime={post.data.publishDate}>
              {formatDate(post.data.publishDate)}
            </time>
          </div>
          <span class="text-brand-600">|</span>
          <div class="flex items-center gap-1.5">
            <Icon name="lucide:user" class="size-4 text-accent-400" />
            <span>{post.data.author}</span>
          </div>
        </div>

        {post.data.tags.length > 0 && (
          <div data-reveal style="--reveal-delay: 240ms" class="mt-5 flex flex-wrap gap-2">
            {post.data.tags.map((tag: string) => (
              <span class="rounded-full border border-white/15 bg-white/5 px-2.5 py-0.5 text-xs text-brand-200 backdrop-blur-sm">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="mx-auto max-w-3xl px-5 py-12 lg:px-8 lg:py-16">
      <div class="prose-editorial">
        <Content />
      </div>

      <div data-reveal class="gradient-border relative mt-16 overflow-hidden rounded-3xl border border-brand-200 bg-gradient-to-br from-brand-50 to-accent-50/40 p-8 lg:p-10">
        <div class="dot-grid pointer-events-none absolute inset-0 opacity-40 [mask-image:radial-gradient(ellipse_at_top_right,black,transparent_70%)]"></div>
        <div class="relative">
          <h2 class="font-display text-2xl font-bold tracking-tight text-brand-900">
            Need HVAC Duct Manufacturing?
          </h2>
          <p class="mt-2 text-sm leading-relaxed text-stone-600">
            Duct Masters provides HVAC duct manufacturing and sheet metal fabrication from our facility in Musaffah, Abu Dhabi. Contact us for a competitive quotation on your next project.
          </p>
          <div class="mt-6 flex flex-wrap gap-4">
            <a
              href={business.phoneHref}
              class="btn-shine inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-accent-500 to-brand-500 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-accent-600/30 transition-all hover:-translate-y-0.5 hover:shadow-xl"
            >
              <Icon name="lucide:phone" class="size-4" />
              Call {business.phone}
            </a>
            <a
              href={contactUrl()}
              class="inline-flex items-center gap-2 rounded-xl border border-brand-300 bg-white px-6 py-3.5 text-sm font-semibold text-brand-700 transition-all hover:-translate-y-0.5 hover:border-brand-400 hover:shadow-lg"
            >
              <Icon name="lucide:message-square" class="size-4" />
              Request a Quote
            </a>
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
