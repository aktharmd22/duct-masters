---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { blogUrl } from '../../lib/urls';
import { business } from '../../data/business';
import { Icon } from 'astro-icon/components';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

const categoryColors: Record<string, { bg: string; text: string }> = {
  industry: { bg: 'bg-brand-100', text: 'text-brand-700' },
  guides: { bg: 'bg-accent-100', text: 'text-accent-700' },
  projects: { bg: 'bg-stone-200', text: 'text-stone-700' },
  news: { bg: 'bg-stone-100', text: 'text-stone-600' },
};

function formatDate(iso: string): string {
  const date = new Date(iso + 'T00:00:00');
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title={`Industry Insights & Guides | ${business.name}`}
  description="HVAC duct manufacturing insights, metal fabrication guides, and industry news from Duct Masters. Expert content for contractors and project managers in Abu Dhabi and the UAE."
>
  <Breadcrumbs crumbs={[{ label: 'Blog' }]} />

  <section class="mx-auto max-w-7xl px-5 py-10 lg:px-8 lg:py-16">
    <div class="text-center">
      <h1 class="font-display text-3xl text-brand-900 sm:text-4xl lg:text-5xl">
        Industry Insights & Guides
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-stone-600">
        Technical guides, industry insights, and project advice from the team at
        {business.name}. Helping contractors and project managers make informed decisions about HVAC ductwork and metal fabrication.
      </p>
    </div>

    {posts.length === 0 ? (
      <p class="mt-12 text-center text-stone-500">
        No blog posts yet. Check back soon for industry insights and guides.
      </p>
    ) : (
      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => {
          const colors = categoryColors[post.data.category] || categoryColors.news;
          return (
            <a
              href={blogUrl(post.id)}
              class="card-hover group flex flex-col rounded-xl border border-stone-200 bg-white"
            >
              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-center gap-3">
                  <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-semibold capitalize ${colors.bg} ${colors.text}`}>
                    {post.data.category}
                  </span>
                  {post.data.readingTime && (
                    <span class="flex items-center gap-1 text-xs text-stone-400">
                      <Icon name="lucide:clock" class="size-3" />
                      {post.data.readingTime}
                    </span>
                  )}
                </div>

                <h2 class="mt-3 font-display text-lg text-brand-900 group-hover:text-brand-700">
                  {post.data.title}
                </h2>

                <p class="mt-2 flex-1 text-sm leading-relaxed text-stone-600">
                  {post.data.description}
                </p>

                <div class="mt-4 flex items-center gap-2 border-t border-stone-100 pt-4 text-xs text-stone-400">
                  <Icon name="lucide:calendar" class="size-3.5" />
                  <time datetime={post.data.publishDate}>
                    {formatDate(post.data.publishDate)}
                  </time>
                  <span class="text-stone-300">|</span>
                  <span>{post.data.author}</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </section>
</BaseLayout>
