---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { business } from '../data/business';
---

<BaseLayout
  title={`Contact ${business.name} | HVAC Duct Manufacturing Abu Dhabi`}
  description={`Contact ${business.name} in Musaffah, Abu Dhabi. Call ${business.phone} or email ${business.email} for HVAC duct manufacturing and sheet metal fabrication quotations.`}
>
  <!-- Hero -->
  <section class="relative -mt-16 flex min-h-[60vh] items-center overflow-hidden bg-brand-950 pt-32 pb-24 lg:-mt-[76px] lg:min-h-[64vh] lg:pt-40 lg:pb-28">
    <div class="absolute inset-0">
      <img src="/images/gallery/engineers-reviewing-drawings-in-….webp" alt="" class="h-full w-full object-cover" width="1200" height="670" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-b from-brand-950/92 via-brand-950/82 to-brand-950/96"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_40%,_rgba(46,150,227,0.28),_transparent_70%)]"></div>
      <div class="blueprint-grid-dark absolute inset-0 opacity-30"></div>
    </div>
    <div class="relative mx-auto w-full max-w-3xl px-5 text-center lg:px-8">
      <span data-reveal class="mx-auto inline-flex size-14 items-center justify-center rounded-2xl border border-white/20 bg-white/10 text-white shadow-lg backdrop-blur-sm">
        <Icon name="lucide:mail" class="size-7" />
      </span>
      <h1 data-reveal style="--reveal-delay: 80ms" class="mt-6 font-display text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">Contact Us</h1>
      <p data-reveal style="--reveal-delay: 160ms" class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-brand-100">
        Get in touch with our team for HVAC duct manufacturing, sheet metal fabrication quotations, or project inquiries.
      </p>
    </div>
  </section>

  <section class="relative overflow-hidden bg-stone-50 py-24 lg:py-32">
    <div class="dot-grid absolute inset-0 opacity-40"></div>
    <div class="absolute -top-20 right-0 h-96 w-96 rounded-full bg-accent-500/10 blur-[120px]"></div>
    <div class="relative mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <!-- Contact Info -->
        <div>
          <h2 data-reveal class="font-display text-2xl font-bold tracking-tight text-brand-900 sm:text-3xl">Get in Touch</h2>
          <p data-reveal style="--reveal-delay: 80ms" class="mt-3 text-stone-600">
            Send us your project drawings and specifications for a competitive quotation. We typically respond within one business day.
          </p>

          <div class="mt-8 space-y-5">
            <div data-reveal data-spotlight style="--reveal-delay: 120ms" class="group spotlight-card gradient-border flex items-start gap-4 rounded-2xl border border-stone-200 bg-white p-5 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-brand-900/10">
              <div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-accent-500/15 to-brand-500/10 ring-1 ring-brand-100 transition-all duration-300 group-hover:-rotate-6 group-hover:scale-110 group-hover:from-accent-500 group-hover:to-brand-500">
                <Icon name="lucide:map-pin" class="size-6 text-brand-600 transition-colors group-hover:text-white" />
              </div>
              <div>
                <h3 class="font-semibold text-brand-900">Address</h3>
                <p class="mt-1 text-stone-600">
                  {business.address.street}<br />
                  {business.address.city}, {business.address.country}
                </p>
                <a
                  href={business.googleMapsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-1 inline-flex items-center gap-1 text-sm font-medium text-brand-600 hover:text-brand-700"
                >
                  <Icon name="lucide:external-link" class="size-3.5" />
                  View on Google Maps
                </a>
              </div>
            </div>

            <div data-reveal data-spotlight style="--reveal-delay: 180ms" class="group spotlight-card gradient-border flex items-start gap-4 rounded-2xl border border-stone-200 bg-white p-5 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-brand-900/10">
              <div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-accent-500/15 to-brand-500/10 ring-1 ring-brand-100 transition-all duration-300 group-hover:-rotate-6 group-hover:scale-110 group-hover:from-accent-500 group-hover:to-brand-500">
                <Icon name="lucide:phone" class="size-6 text-brand-600 transition-colors group-hover:text-white" />
              </div>
              <div>
                <h3 class="font-semibold text-brand-900">Phone</h3>
                <p class="mt-1 text-stone-600">
                  <a href={business.phoneHref} class="hover:text-brand-600">{business.phone}</a>
                </p>
                <p class="mt-0.5 text-sm text-stone-500">Mobile / WhatsApp: {business.phoneSecondary}</p>
              </div>
            </div>

            <div data-reveal data-spotlight style="--reveal-delay: 240ms" class="group spotlight-card gradient-border flex items-start gap-4 rounded-2xl border border-stone-200 bg-white p-5 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-brand-900/10">
              <div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-accent-500/15 to-brand-500/10 ring-1 ring-brand-100 transition-all duration-300 group-hover:-rotate-6 group-hover:scale-110 group-hover:from-accent-500 group-hover:to-brand-500">
                <Icon name="lucide:mail" class="size-6 text-brand-600 transition-colors group-hover:text-white" />
              </div>
              <div>
                <h3 class="font-semibold text-brand-900">Email</h3>
                <p class="mt-1 text-stone-600">
                  <a href={`mailto:${business.email}`} class="hover:text-brand-600">{business.email}</a>
                </p>
              </div>
            </div>

            <div data-reveal data-spotlight style="--reveal-delay: 300ms" class="group spotlight-card gradient-border flex items-start gap-4 rounded-2xl border border-stone-200 bg-white p-5 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-brand-900/10">
              <div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-accent-500/15 to-brand-500/10 ring-1 ring-brand-100 transition-all duration-300 group-hover:-rotate-6 group-hover:scale-110 group-hover:from-accent-500 group-hover:to-brand-500">
                <Icon name="lucide:clock" class="size-6 text-brand-600 transition-colors group-hover:text-white" />
              </div>
              <div>
                <h3 class="font-semibold text-brand-900">Business Hours</h3>
                <div class="mt-1 text-stone-600">
                  {business.hours.map((schedule) => (
                    <p>{schedule.days}: {schedule.hours}</p>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div data-reveal="right" class="relative">
          <div class="pointer-events-none absolute -inset-4 rounded-[2.5rem] bg-gradient-to-br from-accent-500/15 to-brand-500/10 blur-2xl"></div>
          <div class="relative rounded-3xl border border-stone-200 bg-white p-8 shadow-2xl shadow-brand-900/10">
            <h2 class="font-display text-xl font-bold tracking-tight text-brand-900">Send Us a Message</h2>
            <p class="mt-2 text-sm text-stone-500">
              Include your project details or upload drawings for a faster quotation.
            </p>

            <form class="mt-6 space-y-5" action="#" method="POST">
              <div>
                <label for="name" class="block text-sm font-medium text-stone-700">Full Name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="mt-1 block w-full rounded-xl border border-stone-300 px-4 py-2.5 text-sm text-stone-900 placeholder-stone-400 transition-colors focus:border-accent-500 focus:ring-1 focus:ring-accent-500"
                  placeholder="Your name"
                />
              </div>

              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label for="email" class="block text-sm font-medium text-stone-700">Email *</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="mt-1 block w-full rounded-xl border border-stone-300 px-4 py-2.5 text-sm text-stone-900 placeholder-stone-400 transition-colors focus:border-accent-500 focus:ring-1 focus:ring-accent-500"
                    placeholder="you@company.com"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-stone-700">Phone</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="mt-1 block w-full rounded-xl border border-stone-300 px-4 py-2.5 text-sm text-stone-900 placeholder-stone-400 transition-colors focus:border-accent-500 focus:ring-1 focus:ring-accent-500"
                    placeholder="+971"
                  />
                </div>
              </div>

              <div>
                <label for="company" class="block text-sm font-medium text-stone-700">Company</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  class="mt-1 block w-full rounded-xl border border-stone-300 px-4 py-2.5 text-sm text-stone-900 placeholder-stone-400 transition-colors focus:border-accent-500 focus:ring-1 focus:ring-accent-500"
                  placeholder="Your company name"
                />
              </div>

              <div>
                <label for="service" class="block text-sm font-medium text-stone-700">Service Interested In</label>
                <select
                  id="service"
                  name="service"
                  class="mt-1 block w-full rounded-xl border border-stone-300 px-4 py-2.5 text-sm text-stone-900 transition-colors focus:border-accent-500 focus:ring-1 focus:ring-accent-500"
                >
                  <option value="">Select a service</option>
                  <option value="sheet-metal-fabrication">Sheet Metal Fabrication</option>
                  <option value="duct-fabrication">HVAC Duct Manufacturing</option>
                  <option value="laser-cutting">Laser Cutting Services</option>
                  <option value="cnc-forming">CNC Metal Forming</option>
                  <option value="welding-services">Industrial Welding</option>
                  <option value="metal-rolling-punching">Metal Rolling & Punching</option>
                  <option value="custom-industrial-fabrication">Custom Industrial Fabrication</option>
                  <option value="powder-coating-finishing">Powder Coating & Finishing</option>
                  <option value="design-engineering">Duct System Design & Engineering</option>
                  <option value="supply-delivery">Duct Supply & Installation</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-stone-700">Project Details *</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="mt-1 block w-full rounded-xl border border-stone-300 px-4 py-2.5 text-sm text-stone-900 placeholder-stone-400 transition-colors focus:border-accent-500 focus:ring-1 focus:ring-accent-500"
                  placeholder="Describe your project requirements, quantities, materials, and any drawings or specifications you have…"
                ></textarea>
              </div>

              <button
                type="submit"
                class="btn-shine group inline-flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-br from-accent-500 to-brand-500 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-accent-600/30 transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-accent-600/50"
              >
                <Icon name="lucide:send" class="size-4 transition-transform group-hover:translate-x-0.5" />
                Send Inquiry
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
