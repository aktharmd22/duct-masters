---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { business } from '../data/business';
---

<BaseLayout
  title={`Contact ${business.name} | HVAC Duct Manufacturing Abu Dhabi`}
  description={`Contact ${business.name} in Musaffah, Abu Dhabi. Call ${business.phone} or email ${business.email} for HVAC duct manufacturing and sheet metal fabrication quotations.`}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-900 to-brand-800 py-16 lg:py-20">
    <div class="absolute inset-0"><img src="/images/gallery/engineers-reviewing-drawings-in-….webp" alt="" class="h-full w-full object-cover opacity-10" width="1200" height="670" loading="eager" /></div>
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h1 class="font-display text-4xl text-white sm:text-5xl">Contact Us</h1>
      <p class="mt-4 max-w-2xl text-lg text-brand-200">
        Get in touch with our team for HVAC duct manufacturing, sheet metal fabrication quotations, or project inquiries.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-5 py-16 lg:px-8 lg:py-24">
    <div class="grid gap-12 lg:grid-cols-2">
      <!-- Contact Info -->
      <div>
        <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">Get in Touch</h2>
        <p class="mt-3 text-stone-600">
          Send us your project drawings and specifications for a competitive quotation. We typically respond within one business day.
        </p>

        <div class="mt-8 space-y-6">
          <div class="flex items-start gap-4">
            <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-brand-50">
              <Icon name="lucide:map-pin" class="size-5 text-brand-700" />
            </div>
            <div>
              <h3 class="font-semibold text-brand-900">Address</h3>
              <p class="mt-1 text-stone-600">
                {business.address.street}<br />
                {business.address.city}, {business.address.country}
              </p>
              <a
                href={business.googleMapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-1 inline-flex items-center gap-1 text-sm font-medium text-brand-600 hover:text-brand-700"
              >
                <Icon name="lucide:external-link" class="size-3.5" />
                View on Google Maps
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-brand-50">
              <Icon name="lucide:phone" class="size-5 text-brand-700" />
            </div>
            <div>
              <h3 class="font-semibold text-brand-900">Phone</h3>
              <p class="mt-1 text-stone-600">
                <a href={business.phoneHref} class="hover:text-brand-600">{business.phone}</a>
              </p>
              <p class="mt-0.5 text-sm text-stone-500">Mobile / WhatsApp: {business.phoneSecondary}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-brand-50">
              <Icon name="lucide:mail" class="size-5 text-brand-700" />
            </div>
            <div>
              <h3 class="font-semibold text-brand-900">Email</h3>
              <p class="mt-1 text-stone-600">
                <a href={`mailto:${business.email}`} class="hover:text-brand-600">{business.email}</a>
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-brand-50">
              <Icon name="lucide:clock" class="size-5 text-brand-700" />
            </div>
            <div>
              <h3 class="font-semibold text-brand-900">Business Hours</h3>
              <div class="mt-1 text-stone-600">
                {business.hours.map((schedule) => (
                  <p>{schedule.days}: {schedule.hours}</p>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <div class="rounded-xl border border-stone-200 bg-white p-8">
          <h2 class="font-display text-xl text-brand-900">Send Us a Message</h2>
          <p class="mt-2 text-sm text-stone-500">
            Include your project details or upload drawings for a faster quotation.
          </p>

          <form class="mt-6 space-y-5" action="#" method="POST">
            <div>
              <label for="name" class="block text-sm font-medium text-stone-700">Full Name *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="mt-1 block w-full rounded-lg border border-stone-300 px-4 py-2.5 text-sm text-stone-900 placeholder-stone-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500"
                placeholder="Your name"
              />
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label for="email" class="block text-sm font-medium text-stone-700">Email *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="mt-1 block w-full rounded-lg border border-stone-300 px-4 py-2.5 text-sm text-stone-900 placeholder-stone-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500"
                  placeholder="you@company.com"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-stone-700">Phone</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="mt-1 block w-full rounded-lg border border-stone-300 px-4 py-2.5 text-sm text-stone-900 placeholder-stone-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500"
                  placeholder="+971"
                />
              </div>
            </div>

            <div>
              <label for="company" class="block text-sm font-medium text-stone-700">Company</label>
              <input
                type="text"
                id="company"
                name="company"
                class="mt-1 block w-full rounded-lg border border-stone-300 px-4 py-2.5 text-sm text-stone-900 placeholder-stone-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500"
                placeholder="Your company name"
              />
            </div>

            <div>
              <label for="service" class="block text-sm font-medium text-stone-700">Service Interested In</label>
              <select
                id="service"
                name="service"
                class="mt-1 block w-full rounded-lg border border-stone-300 px-4 py-2.5 text-sm text-stone-900 focus:border-brand-500 focus:ring-1 focus:ring-brand-500"
              >
                <option value="">Select a service</option>
                <option value="sheet-metal-fabrication">Sheet Metal Fabrication</option>
                <option value="duct-fabrication">HVAC Duct Manufacturing</option>
                <option value="laser-cutting">Laser Cutting Services</option>
                <option value="cnc-forming">CNC Metal Forming</option>
                <option value="welding-services">Industrial Welding</option>
                <option value="metal-rolling-punching">Metal Rolling & Punching</option>
                <option value="custom-industrial-fabrication">Custom Industrial Fabrication</option>
                <option value="powder-coating-finishing">Powder Coating & Finishing</option>
                <option value="design-engineering">Duct System Design & Engineering</option>
                <option value="supply-delivery">Duct Supply & Installation</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-stone-700">Project Details *</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="mt-1 block w-full rounded-lg border border-stone-300 px-4 py-2.5 text-sm text-stone-900 placeholder-stone-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500"
                placeholder="Describe your project requirements, quantities, materials, and any drawings or specifications you have…"
              ></textarea>
            </div>

            <button
              type="submit"
              class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-all hover:bg-brand-700"
            >
              <Icon name="lucide:send" class="size-4" />
              Send Inquiry
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
