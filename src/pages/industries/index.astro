---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { business } from '../../data/business';
import { contactUrl } from '../../lib/urls';
import { Icon } from 'astro-icon/components';

const industryList = [
  { name: 'HVAC Contractors', slug: 'hvac-contractors', icon: 'lucide:air-vent', desc: 'Duct manufacturing and fabrication services for HVAC contractors across Abu Dhabi.' },
  { name: 'MEP Contractors', slug: 'mep-contractors', icon: 'lucide:cog', desc: 'Coordinated fabrication supporting mechanical, electrical, and plumbing projects.' },
  { name: 'Construction Companies', slug: 'construction-companies', icon: 'lucide:building-2', desc: 'HVAC ductwork and fabricated metal components for construction projects.' },
  { name: 'Industrial Facilities', slug: 'industrial-facilities', icon: 'lucide:factory', desc: 'Heavy-duty ductwork and industrial-grade fabricated components.' },
  { name: 'Commercial Buildings', slug: 'commercial-buildings', icon: 'lucide:building', desc: 'Quality ductwork for offices, retail, hotels, hospitals, and mixed-use developments.' },
  { name: 'Warehouses & Logistics', slug: 'warehouses-logistics-facilities', icon: 'lucide:warehouse', desc: 'Large-volume ductwork and ventilation for distribution centers.' },
  { name: 'Factories & Manufacturing', slug: 'factories-manufacturing-units', icon: 'lucide:wrench', desc: 'Custom fabrication for process ventilation and industrial duct systems.' },
  { name: 'Infrastructure Projects', slug: 'infrastructure-projects', icon: 'lucide:landmark', desc: 'Project-scale fabrication for airports, metro, tunnels, and public facilities.' },
];

// Bento grid: asymmetric column spans (6-col track) + which tiles render as dark "feature" cards
const bentoLayout = [
  'lg:col-span-4', 'lg:col-span-2',
  'lg:col-span-2', 'lg:col-span-2', 'lg:col-span-2',
  'lg:col-span-2', 'lg:col-span-4',
  'lg:col-span-6',
];
const featureIdx = new Set([0, 6, 7]);
---

<BaseLayout
  title={`Industries Served | ${business.name}`}
  description={`${business.name} serves HVAC contractors, MEP contractors, construction companies, industrial facilities, commercial buildings, and infrastructure projects across Abu Dhabi and the UAE.`}
>

  <section class="relative -mt-16 flex min-h-[60vh] items-center overflow-hidden bg-brand-950 pt-32 pb-24 lg:-mt-[76px] lg:min-h-[64vh] lg:pt-40 lg:pb-28">
    <div class="absolute inset-0">
      <img src="/images/gallery/factory-uniforms.webp" alt="" class="h-full w-full object-cover" width="1200" height="670" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-b from-brand-950/92 via-brand-950/82 to-brand-950/96"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_40%,_rgba(46,104,156,0.28),_transparent_70%)]"></div>
      <div class="blueprint-grid-dark absolute inset-0 opacity-30"></div>
    </div>
    <div class="relative mx-auto w-full max-w-3xl px-5 text-center lg:px-8">
      <span data-reveal class="mx-auto inline-flex size-14 items-center justify-center rounded-2xl border border-white/20 bg-white/10 text-white shadow-lg backdrop-blur-sm">
        <Icon name="lucide:building-2" class="size-7" />
      </span>
      <h1 data-reveal style="--reveal-delay: 80ms" class="mt-6 font-display text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">Industries We Serve</h1>
      <p data-reveal style="--reveal-delay: 160ms" class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-brand-100">
        {business.name} provides HVAC duct manufacturing, sheet metal fabrication, and custom metal works to a wide range of industries across Abu Dhabi and the UAE.
      </p>
    </div>
  </section>

  <section class="bg-gradient-to-b from-stone-50 via-white to-stone-50 py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-6">
        {industryList.map((ind, i) => {
          const isFeature = featureIdx.has(i);
          return (
            <a
              href={`/industries/${ind.slug}/`}
              data-reveal
              data-spotlight={!isFeature}
              style={`--reveal-delay: ${(i % 3) * 80}ms`}
              class={`group relative flex flex-col justify-between overflow-hidden rounded-3xl p-7 transition-all duration-500 hover:-translate-y-1.5 ${bentoLayout[i]} ${isFeature ? 'bg-gradient-to-br from-brand-800 to-brand-950 text-white ring-1 ring-white/10 hover:shadow-2xl hover:shadow-brand-900/30' : 'spotlight-card gradient-border border border-stone-200 bg-white shadow-sm hover:shadow-2xl hover:shadow-brand-900/10'}`}
            >
              {isFeature && <div class="blueprint-grid-dark absolute inset-0 opacity-40"></div>}
              {isFeature && <div class="absolute -right-16 -top-16 h-52 w-52 rounded-full bg-accent-500/20 blur-[80px]"></div>}
              <div class="relative max-w-xl">
                <div class={`flex items-center justify-center rounded-2xl transition-all duration-300 group-hover:-rotate-6 group-hover:scale-110 ${isFeature ? 'size-14 bg-white/10 ring-1 ring-white/15' : 'size-12 bg-gradient-to-br from-accent-500/15 to-brand-500/10 ring-1 ring-brand-100 group-hover:from-accent-500 group-hover:to-brand-500'}`}>
                  <Icon name={ind.icon} class={isFeature ? 'size-7 text-accent-400' : 'size-6 text-brand-700 transition-colors group-hover:text-white'} />
                </div>
                <h2 class={`font-display font-bold tracking-tight ${isFeature ? 'mt-5 text-2xl text-white' : 'mt-4 text-lg text-brand-900'}`}>{ind.name}</h2>
                <p class={isFeature ? 'mt-3 leading-relaxed text-brand-200' : 'mt-2 text-sm leading-relaxed text-stone-600'}>{ind.desc}</p>
              </div>
              <div class={`relative mt-6 flex items-center gap-1.5 text-sm font-semibold ${isFeature ? 'text-accent-400' : 'text-brand-600'}`}>
                <span>Learn more</span>
                <Icon name="lucide:arrow-right" class="size-4 transition-transform group-hover:translate-x-1.5" />
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-brand-950 py-16 lg:py-20">
    <div class="absolute inset-0 bg-gradient-to-t from-brand-950 via-brand-950/90 to-brand-900"></div>
    <div class="blueprint-grid-dark absolute inset-0 opacity-70"></div>
    <div class="absolute -bottom-24 left-1/2 h-80 w-[42rem] -translate-x-1/2 rounded-full bg-accent-500/15 blur-[120px]"></div>
    <div class="relative mx-auto max-w-7xl px-5 lg:px-8">
      <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
        <div>
          <h2 class="font-display text-3xl font-bold tracking-tight text-white">Not Sure If We Serve Your Industry?</h2>
          <p class="mt-2 text-brand-200">Contact us to discuss your project. We likely have experience in your sector.</p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-4">
          <a href={business.phoneHref} class="btn-shine group inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-accent-500 to-brand-500 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-accent-600/30 transition-all hover:-translate-y-0.5">
            <Icon name="lucide:phone" class="size-5" />{business.phone}
          </a>
          <a href={contactUrl()} class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 px-6 py-3.5 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:border-white/30 hover:bg-white/10">
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
