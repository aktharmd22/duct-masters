---
import { Icon } from 'astro-icon/components';
import { business, yearsInBusiness } from '../../data/business';
import { serviceTypes, getServiceBySlug } from '../../data/serviceTypes';
import { serviceAreas } from '../../data/serviceAreas';
import { serviceUrl, comboUrl, contactUrl } from '../../lib/urls';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SeoFaq from '../../components/SeoFaq.astro';

import type { ServiceType } from '../../data/serviceTypes';

export function getStaticPaths() {
  return serviceTypes.map((service) => ({
    params: { service: service.slug },
    props: { service },
  }));
}

interface Props {
  service: ServiceType;
}

const { service } = Astro.props;
const years = yearsInBusiness();

const pageTitle = `${service.name} | ${business.name} — Abu Dhabi, UAE`;
const metaDescription = service.description.length > 155
  ? service.description.slice(0, 152) + '...'
  : service.description;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.name,
  description: service.description,
  provider: {
    '@type': 'HVACBusiness',
    name: business.name,
    telephone: business.phone,
    url: business.website,
    address: {
      '@type': 'PostalAddress',
      streetAddress: business.address.street,
      addressLocality: business.address.city,
      addressRegion: business.address.state,
      addressCountry: 'AE',
    },
  },
  areaServed: serviceAreas.map((area) => ({
    '@type': 'City',
    name: area.name,
    containedInPlace: {
      '@type': 'AdministrativeArea',
      name: area.county,
    },
  })),
};
---

<BaseLayout title={pageTitle} description={metaDescription} schema={schema}>
  <Breadcrumbs
    crumbs={[
      { label: 'Services', href: '/services/' },
      { label: service.name },
    ]}
  />

  <section class="mx-auto max-w-7xl px-5 pb-12 pt-8 lg:px-8">
    <div class="lg:flex lg:items-start lg:gap-12">
      <div class="lg:flex-1">
        <h1 class="font-display text-3xl text-brand-900 sm:text-4xl lg:text-5xl">
          {service.name}
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-relaxed text-stone-600">
          {service.description}
        </p>
      </div>
      <div class="mt-8 lg:mt-0 lg:w-96 lg:shrink-0">
        <img
          src={service.image}
          alt={`${service.name} by ${business.name}`}
          class="rounded-xl shadow-lg"
          width="1024"
          height="1024"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Process steps -->
  <section class="border-t border-stone-200/60 bg-white py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">
        Our {service.name} Process
      </h2>
      <p class="mt-3 max-w-2xl text-stone-600">
        Every project follows a structured process to ensure quality and accuracy.
      </p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {service.process.map((step, index) => (
          <div class="relative rounded-xl border border-stone-200/60 bg-stone-50 p-6">
            <div class="flex size-10 items-center justify-center rounded-full bg-brand-800 text-sm font-bold text-white">
              {index + 1}
            </div>
            <h3 class="mt-4 text-base font-semibold text-stone-900">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Areas served -->
  <section class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">
      Areas We Serve for {service.name}
    </h2>
    <p class="mt-3 max-w-2xl text-stone-600">
      We provide {service.name.toLowerCase()} to locations across {business.serviceRadius}.
      Select your area for local details.
    </p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {serviceAreas.filter(a => a.featured).map((area) => (
        <a
          href={comboUrl(area.slug, service.slug)}
          class="group rounded-xl border border-stone-200/60 bg-white p-5 transition-all hover:border-brand-200 hover:shadow-md"
        >
          <div class="flex items-center gap-3">
            <Icon name="lucide:map-pin" class="size-5 text-brand-500" />
            <span class="font-semibold text-stone-800 group-hover:text-brand-800">{area.name}</span>
          </div>
          <p class="mt-2 text-sm text-stone-500">{area.county}</p>
        </a>
      ))}
    </div>
  </section>

  <div class="border-t border-stone-200/60 bg-white">
    <SeoFaq service={service} />
  </div>

  <section class="bg-brand-900 py-16">
    <div class="mx-auto max-w-4xl px-5 text-center lg:px-8">
      <h2 class="font-display text-2xl text-white sm:text-3xl">
        Need {service.name}?
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-brand-200">
        {business.name} has been serving Abu Dhabi and the UAE for over {years} years.
        Contact us for a competitive quotation for {service.name.toLowerCase()}.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={business.phoneHref}
          class="inline-flex items-center gap-2 rounded-lg bg-brand-500 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-all hover:bg-brand-600"
        >
          <Icon name="lucide:phone" class="size-4" />
          {business.phone}
        </a>
        <a
          href={contactUrl()}
          class="inline-flex items-center gap-2 rounded-lg border border-brand-300/40 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-brand-800"
        >
          <Icon name="lucide:mail" class="size-4" />
          Request a Quote
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
