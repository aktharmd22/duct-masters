---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { business, yearsInBusiness } from '../data/business';
import { serviceTypes } from '../data/serviceTypes';
import { serviceAreas } from '../data/serviceAreas';
import { serviceUrl, areaUrl, contactUrl } from '../lib/urls';

const years = yearsInBusiness();

const galleryImages = [
  { src: '/images/gallery/laser-machine-operator.webp', alt: 'CNC laser cutting machine in operation at Duct Masters' },
  { src: '/images/gallery/technician_inspecting_hvac_duct_….webp', alt: 'Quality inspection of HVAC ductwork' },
  { src: '/images/gallery/workers_collaborating_on_metal_f….webp', alt: 'Metal component fabrication at Musaffah facility' },
  { src: '/images/gallery/engineers_reviewing_drawings_in_….webp', alt: 'Engineers reviewing fabrication drawings' },
  { src: '/images/gallery/logo-on-uniform.webp', alt: 'Duct Masters factory team' },
  { src: '/images/gallery/preparing-components.webp', alt: 'Preparing metal components for fabrication' },
  { src: '/images/gallery/factory-uniforms.webp', alt: 'Duct Masters workshop team in uniform' },
  { src: '/images/gallery/workers_handling_metal_sheets_wo….webp', alt: 'Handling sheet metal at Duct Masters facility' },
];

const stats = [
  { count: years, suffix: '+', en: 'Years Experience', ar: 'سنوات الخبرة', icon: 'lucide:award' },
  { count: 10, suffix: '', en: 'Fabrication Services', ar: 'خدمات التشكيل', icon: 'lucide:settings' },
  { text: 'M-40', en: 'Musaffah Facility', ar: 'منشأة مصفح', icon: 'lucide:map-pin' },
  { text: 'UAE', en: 'Licensed Manufacturer', ar: 'مرخص في الإمارات', icon: 'lucide:shield-check' },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebSite', '@id': `${business.website}/#website`, url: business.website, name: business.name, description: business.description, publisher: { '@id': `${business.website}/#business` } },
    { '@type': 'HVACBusiness', '@id': `${business.website}/#business`, name: business.name, legalName: business.legalName, url: business.website, telephone: business.phone, email: business.email, description: business.description, foundingDate: `${business.yearEstablished}`, address: { '@type': 'PostalAddress', streetAddress: business.address.street, addressLocality: business.address.city, addressRegion: business.address.state, addressCountry: 'AE' }, geo: { '@type': 'GeoCoordinates', latitude: business.coordinates.lat, longitude: business.coordinates.lng }, openingHoursSpecification: [{ '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'], opens: '08:00', closes: '17:00' }], areaServed: serviceAreas.filter(a => a.featured).map((area) => ({ '@type': 'City', name: area.name, containedInPlace: { '@type': 'AdministrativeArea', name: area.county } })), hasOfferCatalog: { '@type': 'OfferCatalog', name: 'Fabrication Services', itemListElement: serviceTypes.map(s => ({ '@type': 'Offer', itemOffered: { '@type': 'Service', name: s.name, description: s.description } })) } },
    { '@type': 'WebPage', '@id': `${business.website}/#webpage`, url: business.website, name: `${business.name} | HVAC Duct Manufacturing Abu Dhabi`, isPartOf: { '@id': `${business.website}/#website` }, about: { '@id': `${business.website}/#business` }, description: business.description },
  ],
};
---

<BaseLayout title={`${business.name} | HVAC Duct Manufacturing & Sheet Metal Fabrication Abu Dhabi`} description={business.description} schema={schema}>

  <!-- HERO -->
  <section class="relative -mt-16 flex min-h-[100vh] items-center overflow-hidden bg-brand-950 lg:-mt-[76px]">
    <div class="absolute inset-0">
      <img src="/images/gallery/factory-workshop.webp" alt="Duct Masters manufacturing facility in Musaffah, Abu Dhabi" class="h-full w-full scale-105 object-cover" width="1200" height="670" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-950 via-brand-950/85 to-brand-950/40"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-brand-950 via-transparent to-brand-950/60"></div>
      <div class="blueprint-grid animate-grid-pan absolute inset-0 opacity-60"></div>
      <div class="absolute -top-24 right-0 h-[36rem] w-[36rem] rounded-full bg-accent-500/20 blur-[120px] animate-glow"></div>
      <div class="absolute bottom-0 left-1/4 h-80 w-80 rounded-full bg-brand-500/20 blur-[100px] animate-float-slow"></div>
    </div>

    <div class="relative mx-auto w-full max-w-7xl px-5 pt-28 pb-24 lg:px-8 lg:pt-40 lg:pb-32">
      <div class="max-w-3xl">
        <span data-reveal class="inline-flex items-center gap-2 rounded-full border border-accent-400/30 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-accent-400 backdrop-blur-sm">
          <span class="relative flex size-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-400 opacity-70"></span>
            <span class="relative inline-flex size-2 rounded-full bg-accent-400"></span>
          </span>
          <span class="bilingual" data-lang-en="Musaffah, Abu Dhabi — Since {business.yearEstablished}" data-lang-ar="مصفح، أبوظبي — منذ {business.yearEstablished}">Musaffah, Abu Dhabi — Since {business.yearEstablished}</span>
        </span>
        <h1 data-reveal style="--reveal-delay: 80ms" class="mt-6 font-display text-4xl font-bold leading-[1.1] tracking-tight text-white sm:text-5xl lg:text-6xl">
          <span class="bilingual" data-lang-en="HVAC Duct Manufacturing" data-lang-ar="تصنيع مجاري الهواء">HVAC Duct Manufacturing</span><br />
          <span class="bilingual text-gradient" data-lang-en="&amp; Sheet Metal Fabrication" data-lang-ar="وتشكيل الصفائح المعدنية">&amp; Sheet Metal Fabrication</span>
        </h1>
        <p data-reveal style="--reveal-delay: 160ms" class="bilingual mt-7 max-w-xl text-lg leading-relaxed text-brand-200" data-lang-en="{business.tagline}. Custom ductwork and precision metal fabrication for commercial, industrial, and infrastructure projects — backed by {years}+ years in the UAE." data-lang-ar="{business.tagline}. تصنيع مجاري الهواء وتشكيل المعادن الدقيق للمشاريع التجارية والصناعية والبنية التحتية — بخبرة تتجاوز {years} عاماً في الإمارات.">{business.tagline}. Custom ductwork and precision metal fabrication for commercial, industrial, and infrastructure projects — backed by {years}+ years in the UAE.</p>
        <div data-reveal style="--reveal-delay: 240ms" class="mt-9 flex flex-wrap gap-4">
          <a href={business.phoneHref} class="btn-shine group inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-accent-500 to-brand-500 px-7 py-4 text-sm font-semibold text-white shadow-lg shadow-accent-600/30 transition-all hover:shadow-xl hover:shadow-accent-600/50 hover:-translate-y-0.5">
            <Icon name="lucide:phone" class="size-5 transition-transform group-hover:rotate-12" />
            <span class="bilingual" data-lang-en="Call {business.phone}" data-lang-ar="اتصل {business.phone}">Call {business.phone}</span>
          </a>
          <a href={contactUrl()} class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 px-7 py-4 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:border-white/30 hover:bg-white/10">
            <Icon name="lucide:file-text" class="size-5" />
            <span class="bilingual" data-lang-en="Request a Quote" data-lang-ar="طلب عرض سعر">Request a Quote</span>
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 flex -translate-x-1/2 animate-bounce flex-col items-center gap-2 text-white/40">
      <span class="bilingual text-[10px] uppercase tracking-[0.2em]" data-lang-en="Scroll" data-lang-ar="تصفح">Scroll</span>
      <Icon name="lucide:chevron-down" class="size-4" />
    </div>
  </section>

  <!-- CAPABILITIES TICKER -->
  <div class="relative border-y border-white/5 bg-brand-950 py-5">
    <div class="marquee-mask overflow-hidden">
      <div class="animate-marquee flex w-max items-center gap-10 whitespace-nowrap">
        {[...serviceTypes, ...serviceTypes].map((service) => (
          <span class="flex items-center gap-3 text-sm font-medium uppercase tracking-wider text-brand-300">
            <Icon name={service.icon} class="size-4 text-accent-400" />
            {service.shortName}
            <span class="ml-4 text-brand-700">/</span>
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- STATS -->
  <section class="relative bg-brand-950">
    <div class="mx-auto grid max-w-7xl grid-cols-2 sm:grid-cols-4">
      {stats.map((stat, i) => (
        <div data-reveal style={`--reveal-delay: ${i * 90}ms`} class="group relative flex flex-col items-center justify-center border-b border-white/5 px-4 py-10 text-center transition-colors hover:bg-white/[0.03] sm:border-b-0 [&:not(:last-child)]:sm:border-r [&:not(:last-child)]:sm:border-white/5">
          <div class="flex size-12 items-center justify-center rounded-2xl bg-gradient-to-br from-accent-500/20 to-brand-500/10 ring-1 ring-white/10 transition-transform group-hover:scale-110 group-hover:ring-accent-400/40">
            <Icon name={stat.icon} class="size-6 text-accent-400" />
          </div>
          <span class="mt-4 font-display text-4xl font-bold text-white sm:text-5xl">
            {stat.count !== undefined ? (<><span data-count={stat.count}>0</span>{stat.suffix}</>) : stat.text}
          </span>
          <span class="bilingual mt-1.5 text-xs font-medium uppercase tracking-wider text-brand-300" data-lang-en={stat.en} data-lang-ar={stat.ar}>{stat.en}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- SERVICES -->
  <section class="relative overflow-hidden bg-stone-50 py-24 lg:py-32">
    <div class="dot-grid absolute inset-0 opacity-40"></div>
    <div class="relative mx-auto max-w-7xl px-5 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <span data-reveal class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-white px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-700 shadow-sm">
          <Icon name="lucide:wrench" class="size-3.5" />
          <span class="bilingual" data-lang-en="Our Capabilities" data-lang-ar="قدراتنا">Our Capabilities</span>
        </span>
        <h2 data-reveal style="--reveal-delay: 80ms" class="bilingual mt-5 font-display text-4xl font-bold tracking-tight text-brand-900 sm:text-5xl" data-lang-en="Complete Fabrication Services" data-lang-ar="خدمات التشكيل المتكاملة">Complete Fabrication Services</h2>
        <p data-reveal style="--reveal-delay: 140ms" class="bilingual mx-auto mt-5 text-lg text-stone-600" data-lang-en="From HVAC duct manufacturing to precision laser cutting and custom industrial fabrication — everything you need from a single facility in Musaffah." data-lang-ar="من تصنيع مجاري التكييف إلى القطع بالليزر عالي الدقة والتشكيل الصناعي المخصص — كل ما تحتاجه من منشأة واحدة في مصفح.">From HVAC duct manufacturing to precision laser cutting and custom industrial fabrication — everything you need from a single facility in Musaffah.</p>
      </div>
      <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {serviceTypes.map((service, i) => (
          <a href={serviceUrl(service.slug)} data-reveal style={`--reveal-delay: ${(i % 3) * 90}ms`} class="gradient-border group relative flex flex-col overflow-hidden rounded-3xl border border-stone-200/80 bg-white shadow-sm transition-all duration-500 hover:-translate-y-1.5 hover:shadow-2xl hover:shadow-brand-900/10">
            <div class="relative h-52 overflow-hidden">
              <img src={galleryImages[i % galleryImages.length].src} alt={service.name} class="h-full w-full object-cover transition-transform duration-[900ms] group-hover:scale-110" width="1200" height="670" loading={i < 6 ? 'eager' : 'lazy'} />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-950/90 via-brand-950/25 to-transparent"></div>
              <span class="absolute top-4 right-5 font-display text-5xl font-bold text-white/15">{String(i + 1).padStart(2, '0')}</span>
              <div class="absolute top-4 left-4 flex size-11 items-center justify-center rounded-xl bg-white/10 ring-1 ring-white/20 backdrop-blur-md transition-colors group-hover:bg-accent-500">
                <Icon name={service.icon} class="size-5 text-white" />
              </div>
            </div>
            <div class="flex flex-1 flex-col p-6">
              <h3 class="font-display text-xl font-semibold text-brand-900 transition-colors group-hover:text-brand-600">{service.name}</h3>
              <p class="mt-2.5 line-clamp-2 text-sm leading-relaxed text-stone-600">{service.description}</p>
              <div class="mt-5 flex items-center gap-1.5 text-sm font-semibold text-brand-600">
                <span class="bilingual" data-lang-en="Learn more" data-lang-ar="اعرف المزيد">Learn more</span>
                <Icon name="lucide:arrow-right" class="size-4 transition-transform group-hover:translate-x-1.5" />
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="gradient-animated relative overflow-hidden py-24 lg:py-32">
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="animate-aurora-a absolute -left-24 -top-20 h-[28rem] w-[28rem] rounded-full bg-accent-400/45 blur-[90px]"></div>
      <div class="animate-aurora-b absolute right-0 top-1/4 h-[26rem] w-[26rem] rounded-full bg-brand-300/35 blur-[110px]"></div>
      <div class="animate-aurora-c absolute -bottom-24 left-1/3 h-[26rem] w-[26rem] rounded-full bg-accent-500/35 blur-[100px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid items-center gap-14 lg:grid-cols-2 lg:gap-20">
        <div data-reveal="left" class="relative">
          <div class="absolute -left-6 -top-6 h-28 w-28 rounded-2xl border border-brand-200 dot-grid opacity-70"></div>
          <div class="relative overflow-hidden rounded-3xl shadow-2xl shadow-brand-900/20 ring-1 ring-stone-900/5">
            <img src="/images/gallery/workers_collaborating_on_metal_f….webp" alt="Duct Masters fabrication team at work" class="w-full object-cover" width="1200" height="670" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-950/30 to-transparent"></div>
          </div>
          <div class="absolute -bottom-6 -right-6 hidden rounded-2xl bg-gradient-to-br from-brand-800 to-brand-950 p-6 shadow-xl ring-1 ring-white/10 lg:block">
            <span class="font-display text-4xl font-bold text-white"><span data-count={years}>0</span>+</span>
            <p class="bilingual mt-1 text-xs text-brand-300" data-lang-en="Years in UAE" data-lang-ar="عاماً في الإمارات">Years in UAE</p>
          </div>
        </div>
        <div data-reveal="right">
          <span class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-700">
            <Icon name="lucide:building-2" class="size-3.5" />
            <span class="bilingual" data-lang-en="About Duct Masters" data-lang-ar="عن دكت ماسترز">About Duct Masters</span>
          </span>
          <h2 class="bilingual mt-5 font-display text-4xl font-bold tracking-tight text-brand-900 sm:text-[2.75rem] sm:leading-tight" data-lang-en="Abu Dhabi's Trusted HVAC Duct Manufacturer" data-lang-ar="الشركة الرائدة في تصنيع مجاري التكييف في أبوظبي">Abu Dhabi's Trusted HVAC Duct Manufacturer</h2>
          <p class="mt-6 text-lg leading-relaxed text-stone-600">Duct Masters is an Abu Dhabi-based HVAC duct manufacturing and sheet metal fabrication company operating from M-40, Musaffah. Since {business.yearEstablished}, we have supplied air conditioning ducting products and custom metal fabrication solutions for commercial, industrial, construction, and infrastructure projects across the UAE.</p>
          <p class="mt-4 leading-relaxed text-stone-600">With a focus on quality manufacturing, accurate production, and reliable project support, we serve contractors, HVAC companies, construction firms, facility operators, and industrial clients.</p>
          <div class="mt-9 flex flex-wrap gap-4">
            <a href="/about/" class="btn-shine inline-flex items-center gap-2 rounded-xl bg-brand-600 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-brand-600/20 transition-all hover:-translate-y-0.5 hover:bg-brand-700">
              <span class="bilingual" data-lang-en="Learn More About Us" data-lang-ar="اعرف المزيد عنا">Learn More About Us</span> <Icon name="lucide:arrow-right" class="size-4" />
            </a>
            <a href={business.phoneHref} class="inline-flex items-center gap-2 rounded-xl border border-stone-300 px-6 py-3.5 text-sm font-semibold text-stone-700 transition-all hover:border-brand-300 hover:bg-stone-50">
              <Icon name="lucide:phone" class="size-4" /> {business.phone}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="relative overflow-hidden bg-brand-950 py-24 lg:py-32">
    <div class="blueprint-grid-dark absolute inset-0"></div>
    <div class="absolute -top-32 left-1/2 h-96 w-[40rem] -translate-x-1/2 rounded-full bg-brand-500/15 blur-[130px]"></div>
    <div class="relative mx-auto max-w-7xl px-5 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <span data-reveal class="inline-flex items-center gap-2 rounded-full border border-accent-400/20 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-accent-400">
          <Icon name="lucide:list-checks" class="size-3.5" />
          <span class="bilingual" data-lang-en="Our Process" data-lang-ar="منهجية العمل">Our Process</span>
        </span>
        <h2 data-reveal style="--reveal-delay: 80ms" class="bilingual mt-5 font-display text-4xl font-bold tracking-tight text-white sm:text-5xl" data-lang-en="How We Deliver Your Project" data-lang-ar="كيف ننجز مشروعك">How We Deliver Your Project</h2>
        <p data-reveal style="--reveal-delay: 140ms" class="bilingual mx-auto mt-5 text-lg text-brand-300" data-lang-en="From inquiry to delivery — every project follows a structured process ensuring quality, accuracy, and on-time completion." data-lang-ar="من الاستفسار إلى التسليم — كل مشروع يتبع عملية منظمة تضمن الجودة والدقة والتسليم في الوقت المحدد.">From inquiry to delivery — every project follows a structured process ensuring quality, accuracy, and on-time completion.</p>
      </div>
      <div class="mt-16 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { step: 1, enTitle: 'Submit Inquiry', arTitle: 'تقديم الاستفسار', enDesc: 'Share your project drawings, specifications, and quantities. We review and confirm feasibility within one business day.', arDesc: 'شارك رسومات مشروعك ومواصفاته وكمياته. نقوم بالمراجعة وتأكيد الجدوى خلال يوم عمل واحد.', icon: 'lucide:file-text' },
          { step: 2, enTitle: 'Quotation & Approval', arTitle: 'عرض السعر والموافقة', enDesc: 'Receive a detailed quotation with pricing breakdown, production timeline, and delivery schedule for your review.', arDesc: 'استلم عرض سعر مفصل يتضمن تفصيل الأسعار والجدول الزمني للإنتاج وجدول التسليم للمراجعة.', icon: 'lucide:calculator' },
          { step: 3, enTitle: 'Fabrication', arTitle: 'التصنيع', enDesc: 'Your order enters production. Cutting, forming, welding, assembly, and finishing using CNC equipment and skilled fabricators.', arDesc: 'يدخل طلبك مرحلة الإنتاج. القطع والتشكيل واللحام والتجميع والتشطيب باستخدام معدات CNC وفنيين مهرة.', icon: 'lucide:wrench' },
          { step: 4, enTitle: 'QC & Delivery', arTitle: 'فحص الجودة والتسليم', enDesc: 'Quality inspection, protective packing, and on-time delivery to your project site across Abu Dhabi or the UAE.', arDesc: 'فحص الجودة والتغليف الواقي والتسليم في الوقت المحدد لموقع مشروعك في أبوظبي أو أي مكان في الإمارات.', icon: 'lucide:truck' },
        ].map((item, i) => (
          <div data-reveal style={`--reveal-delay: ${i * 100}ms`} class="group relative rounded-3xl border border-white/10 bg-white/[0.03] p-7 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1.5 hover:border-accent-400/30 hover:bg-white/[0.06]">
            <div class="flex items-center justify-between">
              <div class="flex size-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-accent-500 to-brand-500 font-display text-xl font-bold text-white shadow-lg shadow-accent-600/30 transition-transform group-hover:scale-110">{item.step}</div>
              <Icon name={item.icon} class="size-6 text-accent-400/70 transition-colors group-hover:text-accent-400" />
            </div>
            <h3 class="bilingual mt-6 font-display text-lg font-semibold text-white" data-lang-en={item.enTitle} data-lang-ar={item.arTitle}>{item.enTitle}</h3>
            <p class="bilingual mt-2.5 text-sm leading-relaxed text-brand-300" data-lang-en={item.enDesc} data-lang-ar={item.arDesc}>{item.enDesc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="overflow-hidden bg-stone-50 py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <span data-reveal class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-white px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-700 shadow-sm">
          <Icon name="lucide:camera" class="size-3.5" />
          <span class="bilingual" data-lang-en="Our Workshop" data-lang-ar="الورشة">Our Workshop</span>
        </span>
        <h2 data-reveal style="--reveal-delay: 80ms" class="bilingual mt-5 font-display text-4xl font-bold tracking-tight text-brand-900 sm:text-5xl" data-lang-en="Inside Our Facility" data-lang-ar="داخل منشأتنا">Inside Our Facility</h2>
        <p data-reveal style="--reveal-delay: 140ms" class="bilingual mx-auto mt-5 text-lg text-stone-600" data-lang-en="See our manufacturing workshop in Musaffah — equipped with CNC laser cutters, press brakes, welding stations, and professional fabrication tools." data-lang-ar="شاهد ورشة التصنيع لدينا في مصفح — مجهزة بقواطع ليزر CNC ومكابس ضغط ومحطات لحام وأدوات تشكيل احترافية.">See our manufacturing workshop in Musaffah — equipped with CNC laser cutters, press brakes, welding stations, and professional fabrication tools.</p>
      </div>
    </div>
    <div data-reveal class="marquee-mask mt-14 overflow-hidden">
      <div class="animate-marquee flex w-max gap-5 pb-2 hover:[animation-play-state:paused]" style="animation-duration: 55s">
        {[...galleryImages, ...galleryImages].map((img) => (
          <div class="group relative w-72 shrink-0 overflow-hidden rounded-3xl shadow-lg ring-1 ring-stone-900/5 sm:w-80 lg:w-96">
            <img src={img.src} alt={img.alt} class="h-56 w-full object-cover transition-transform duration-700 group-hover:scale-110 sm:h-64 lg:h-72" width="1200" height="670" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-950/70 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              <div class="absolute bottom-0 left-0 right-0 p-5"><p class="text-xs leading-relaxed text-white/90">{img.alt}</p></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AREAS -->
  <section class="relative overflow-hidden bg-white py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <span data-reveal class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-700">
          <Icon name="lucide:map-pin" class="size-3.5" />
          <span class="bilingual" data-lang-en="Service Areas" data-lang-ar="مناطق الخدمة">Service Areas</span>
        </span>
        <h2 data-reveal style="--reveal-delay: 80ms" class="bilingual mt-5 font-display text-4xl font-bold tracking-tight text-brand-900 sm:text-5xl" data-lang-en="Industrial Zones We Serve" data-lang-ar="المناطق الصناعية التي نخدمها">Industrial Zones We Serve</h2>
        <p data-reveal style="--reveal-delay: 140ms" class="bilingual mx-auto mt-5 text-lg text-stone-600" data-lang-en="Manufacturing and delivering across {business.serviceRadius} with our facility centrally located in Musaffah." data-lang-ar="التصنيع والتسليم في جميع أنحاء {business.serviceRadius} مع موقع منشأتنا المركزي في مصفح.">Manufacturing and delivering across {business.serviceRadius} with our facility centrally located in Musaffah.</p>
      </div>
      <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {serviceAreas.map((area, i) => (
          <a href={areaUrl(area.slug)} data-reveal style={`--reveal-delay: ${(i % 4) * 80}ms`} class="group relative flex items-center gap-4 overflow-hidden rounded-2xl border border-stone-200 bg-stone-50 p-5 transition-all duration-300 hover:-translate-y-1 hover:border-brand-300 hover:bg-white hover:shadow-lg hover:shadow-brand-900/5">
            <div class="flex size-11 shrink-0 items-center justify-center rounded-xl bg-brand-50 ring-1 ring-brand-100 transition-colors group-hover:bg-brand-500 group-hover:ring-brand-500"><Icon name="lucide:map-pin" class="size-5 text-brand-600 transition-colors group-hover:text-white" /></div>
            <div><h3 class="font-semibold text-stone-800 transition-colors group-hover:text-brand-800">{area.name}</h3><p class="text-xs text-stone-500">{area.county}</p></div>
            <Icon name="lucide:arrow-up-right" class="ml-auto size-4 text-stone-300 transition-all group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-brand-500" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden bg-brand-950">
    <div class="absolute inset-0"><img src="/images/gallery/workers_fabricating_sheet_metal_….webp" alt="Duct Masters fabrication workshop" class="h-full w-full object-cover opacity-20" width="1200" height="670" loading="lazy" /></div>
    <div class="absolute inset-0 bg-gradient-to-t from-brand-950 via-brand-950/85 to-brand-950/70"></div>
    <div class="blueprint-grid-dark absolute inset-0 opacity-70"></div>
    <div class="absolute -bottom-24 left-1/2 h-80 w-[42rem] -translate-x-1/2 rounded-full bg-accent-500/15 blur-[120px]"></div>
    <div class="relative mx-auto max-w-4xl px-5 py-24 text-center lg:px-8 lg:py-32">
      <h2 data-reveal class="bilingual font-display text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl" data-lang-en="Ready to Start Your Project?" data-lang-ar="هل أنت مستعد لبدء مشروعك؟">Ready to Start Your Project?</h2>
      <p data-reveal style="--reveal-delay: 80ms" class="bilingual mx-auto mt-6 max-w-xl text-lg text-brand-200" data-lang-en="Send us your drawings and specifications. We provide competitive quotations for HVAC duct manufacturing, sheet metal fabrication, and custom metal works across Abu Dhabi and the UAE." data-lang-ar="أرسل لنا رسوماتك ومواصفاتك. نقدم عروض أسعار تنافسية لتصنيع مجاري التكييف وتشكيل الصفائح المعدنية والأعمال المعدنية المخصصة في جميع أنحاء أبوظبي والإمارات.">Send us your drawings and specifications. We provide competitive quotations for HVAC duct manufacturing, sheet metal fabrication, and custom metal works across Abu Dhabi and the UAE.</p>
      <div data-reveal style="--reveal-delay: 160ms" class="mt-11 flex flex-wrap items-center justify-center gap-4">
        <a href={business.phoneHref} class="btn-shine group inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-accent-500 to-brand-500 px-8 py-4 text-sm font-semibold text-white shadow-lg shadow-accent-600/30 transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-accent-600/50"><Icon name="lucide:phone" class="size-5 transition-transform group-hover:rotate-12" />{business.phone}</a>
        <a href={`mailto:${business.email}`} class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 px-8 py-4 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:border-white/30 hover:bg-white/10"><Icon name="lucide:mail" class="size-5" />{business.email}</a>
        <a href={business.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 px-8 py-4 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:border-white/30 hover:bg-white/10"><Icon name="lucide:map-pin" class="size-5" /><span class="bilingual" data-lang-en="Visit Us in Musaffah" data-lang-ar="زرنا في مصفح">Visit Us in Musaffah</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
