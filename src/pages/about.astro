---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { business, yearsInBusiness } from '../data/business';
import { serviceAreas } from '../data/serviceAreas';

const years = yearsInBusiness();
---

<BaseLayout
  title={`About ${business.name} | HVAC Duct Manufacturing Abu Dhabi`}
  description={`${business.name} is an Abu Dhabi-based HVAC duct manufacturing and sheet metal fabrication company. Learn about our facility, capabilities, and ${years}+ years of experience serving the UAE.`}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-900 to-brand-800 py-16 lg:py-20">
    <div class="absolute inset-0"><img src="/images/gallery/logo-on-uniform.webp" alt="" class="h-full w-full object-cover opacity-12" width="1200" height="670" loading="eager" /></div>
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h1 class="font-display text-4xl text-white sm:text-5xl">About Duct Masters</h1>
      <p class="mt-4 max-w-2xl text-lg text-brand-200">
        {business.tagline}. {years}+ years of manufacturing experience serving contractors and projects across the UAE.
      </p>
    </div>
  </section>

  <!-- Content -->
  <div class="mx-auto max-w-7xl px-5 py-16 lg:px-8 lg:py-24">
    <div class="grid gap-12 lg:grid-cols-3">
      <!-- Main content -->
      <div class="lg:col-span-2">
        <div class="prose-editorial max-w-none">
          <h2>Our Story</h2>
          <p>
            {business.name} ({business.legalName}) was established in {business.yearEstablished} and has grown
            into one of Abu Dhabi's leading HVAC duct manufacturing and sheet metal fabrication companies.
            Operating from our facility in {business.address.street}, we serve commercial, industrial,
            construction, and infrastructure projects across Abu Dhabi and the wider UAE.
          </p>
          <p>
            With a focus on quality manufacturing, accurate production, and reliable project support,
            we have built a reputation for delivering fabricated metal products and ductwork that
            meet the highest standards. Our team combines skilled craftsmanship with modern
            CNC machinery to handle projects of all sizes.
          </p>

          <h2>Our Facility</h2>
          <p>
            Our manufacturing facility in Musaffah, Abu Dhabi, is equipped with CNC laser cutters,
            CNC press brakes, shearing machines, rolling equipment, welding stations, and powder
            coating capabilities. This allows us to offer a complete range of fabrication services
            under one roof — from raw sheet metal to finished, coated products ready for installation.
          </p>

          <h2>Our Values</h2>
          <div class="mt-6 grid gap-6 sm:grid-cols-2">
            <div class="rounded-xl border border-stone-200 bg-white p-6">
              <div class="flex size-10 items-center justify-center rounded-lg bg-brand-50">
                <Icon name="lucide:ruler" class="size-5 text-brand-700" />
              </div>
              <h3 class="mt-3 font-semibold text-brand-900">Precision</h3>
              <p class="mt-2 text-sm text-stone-600">
                Every component is manufactured to exact specifications using CNC machinery
                and quality control processes.
              </p>
            </div>
            <div class="rounded-xl border border-stone-200 bg-white p-6">
              <div class="flex size-10 items-center justify-center rounded-lg bg-brand-50">
                <Icon name="lucide:shield-check" class="size-5 text-brand-700" />
              </div>
              <h3 class="mt-3 font-semibold text-brand-900">Reliability</h3>
              <p class="mt-2 text-sm text-stone-600">
                On-time delivery and consistent quality — we understand that projects
                depend on dependable suppliers.
              </p>
            </div>
            <div class="rounded-xl border border-stone-200 bg-white p-6">
              <div class="flex size-10 items-center justify-center rounded-lg bg-brand-50">
                <Icon name="lucide:users" class="size-5 text-brand-700" />
              </div>
              <h3 class="mt-3 font-semibold text-brand-900">Partnership</h3>
              <p class="mt-2 text-sm text-stone-600">
                We work closely with contractors, consultants, and project teams to
                ensure specifications are met and schedules are maintained.
              </p>
            </div>
            <div class="rounded-xl border border-stone-200 bg-white p-6">
              <div class="flex size-10 items-center justify-center rounded-lg bg-brand-50">
                <Icon name="lucide:trending-up" class="size-5 text-brand-700" />
              </div>
              <h3 class="mt-3 font-semibold text-brand-900">Continuous Improvement</h3>
              <p class="mt-2 text-sm text-stone-600">
                We invest in modern equipment and training to continuously improve
                our manufacturing capabilities and service quality.
              </p>
            </div>
          </div>

          <h2>Service Areas</h2>
          <p>
            From our base in Musaffah, we deliver HVAC ductwork and fabricated metal products
            to locations across Abu Dhabi and the UAE, including:
          </p>
          <ul>
            {serviceAreas.filter(a => a.featured).map((area) => (
              <li>{area.name}</li>
            ))}
            <li>…and more across the UAE</li>
          </ul>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-8">
        <div class="rounded-xl border border-stone-200 bg-stone-50 p-6">
          <h3 class="font-display text-lg text-brand-900">Quick Facts</h3>
          <dl class="mt-4 space-y-3">
            <div class="flex justify-between gap-4">
              <dt class="text-sm text-stone-500">Established</dt>
              <dd class="text-sm font-medium text-stone-800">{business.yearEstablished}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-sm text-stone-500">Location</dt>
              <dd class="text-sm font-medium text-stone-800">{business.address.street}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-sm text-stone-500">License</dt>
              <dd class="text-sm font-medium text-stone-800">{business.license}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-sm text-stone-500">Service Area</dt>
              <dd class="text-sm font-medium text-stone-800">{business.serviceRadius}</dd>
            </div>
          </dl>
        </div>

        <div class="rounded-xl bg-brand-900 p-6 text-center">
          <h3 class="font-display text-lg text-white">Get a Quote</h3>
          <p class="mt-2 text-sm text-brand-200">
            Send us your project details for a competitive quotation.
          </p>
          <a
            href={business.phoneHref}
            class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-brand-500 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-brand-600"
          >
            <Icon name="lucide:phone" class="size-4" />
            {business.phone}
          </a>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
