---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';
import { business } from '../../data/business';
import { serviceAreas } from '../../data/serviceAreas';
import { areaUrl, contactUrl } from '../../lib/urls';
---

<BaseLayout
  title={`Service Areas | ${business.name}`}
  description={`${business.name} serves industrial and commercial zones across ${business.serviceRadius}. See our full list of service areas for HVAC duct manufacturing and metal fabrication.`}
>
  <Breadcrumbs crumbs={[{ label: 'Service Areas' }]} />

  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="max-w-3xl animate-fade-up">
        <h1 class="font-display text-4xl text-brand-900 sm:text-5xl">
          Areas We Serve
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-stone-600">
          Based in Musaffah, {business.name} delivers HVAC ductwork and fabricated metal products
          to locations across Abu Dhabi and the UAE. We serve industrial zones, commercial districts,
          and construction project sites throughout the emirate.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-16 lg:pb-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {serviceAreas.map((area, i) => (
          <a
            href={areaUrl(area.slug)}
            class={`card-hover group rounded-xl border border-stone-200 bg-white p-6 animate-fade-up stagger-${Math.min(i + 1, 6)}`}
          >
            <div class="flex items-center justify-between">
              <h2 class="font-display text-lg text-brand-900">{area.name}</h2>
              {area.featured && (
                <span class="inline-block rounded-full bg-brand-100 px-2 py-0.5 text-[11px] font-semibold text-brand-700">
                  Featured
                </span>
              )}
            </div>
            <p class="mt-1 text-sm text-stone-500">{area.county}</p>
            <div class="mt-3 flex items-center gap-1.5 text-sm text-stone-600">
              <Icon name="lucide:building-2" class="size-4 text-stone-400" />
              <span>Industrial & commercial</span>
            </div>
            <p class="mt-3 line-clamp-2 text-sm leading-relaxed text-stone-500">
              {area.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-gradient-to-b from-brand-900 to-brand-950">
    <div class="mx-auto max-w-7xl px-5 py-12 lg:px-8 lg:py-16">
      <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
        <div>
          <h2 class="font-display text-3xl text-white">Need Fabrication in Your Area?</h2>
          <p class="mt-2 text-brand-200">
            We deliver across Abu Dhabi and the UAE. Contact us for delivery availability to your project location.
          </p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-4">
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-2 rounded-lg bg-brand-500 px-6 py-3 text-sm font-semibold text-white shadow-lg transition-all hover:bg-brand-600"
          >
            <Icon name="lucide:phone" class="size-5" />
            {business.phone}
          </a>
          <a
            href={contactUrl()}
            class="inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-white/20"
          >
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
