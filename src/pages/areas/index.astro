---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { business } from '../../data/business';
import { serviceAreas } from '../../data/serviceAreas';
import { areaUrl, contactUrl } from '../../lib/urls';
---

<BaseLayout
  title={`Service Areas | ${business.name}`}
  description={`${business.name} serves industrial and commercial zones across ${business.serviceRadius}. See our full list of service areas for HVAC duct manufacturing and metal fabrication.`}
>

  <section class="relative -mt-16 flex min-h-[60vh] items-center overflow-hidden bg-brand-950 pt-32 pb-24 lg:-mt-[76px] lg:min-h-[64vh] lg:pt-40 lg:pb-28">
    <div class="absolute inset-0">
      <img src="/images/gallery/factory-workshop.webp" alt="" class="h-full w-full object-cover" width="1200" height="670" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-b from-brand-950/92 via-brand-950/82 to-brand-950/96"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_40%,_rgba(46,104,156,0.28),_transparent_70%)]"></div>
      <div class="blueprint-grid-dark absolute inset-0 opacity-30"></div>
    </div>
    <div class="relative mx-auto w-full max-w-3xl px-5 text-center lg:px-8">
      <span data-reveal class="mx-auto inline-flex size-14 items-center justify-center rounded-2xl border border-white/20 bg-white/10 text-white shadow-lg backdrop-blur-sm">
        <Icon name="lucide:map-pin" class="size-7" />
      </span>
      <h1 data-reveal style="--reveal-delay: 80ms" class="mt-6 font-display text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Areas We Serve
      </h1>
      <p data-reveal style="--reveal-delay: 160ms" class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-brand-100">
        Based in Musaffah, {business.name} delivers HVAC ductwork and fabricated metal products
        to locations across Abu Dhabi and the UAE. We serve industrial zones, commercial districts,
        and construction project sites throughout the emirate.
      </p>
    </div>
  </section>

  <section class="bg-gradient-to-b from-stone-50 via-white to-stone-50 py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {serviceAreas.map((area, i) => (
          <a
            href={areaUrl(area.slug)}
            data-reveal
            data-spotlight
            style={`--reveal-delay: ${(i % 4) * 90}ms`}
            class="group gradient-border spotlight-card rounded-3xl border border-stone-200 bg-white p-6 shadow-sm transition-all duration-500 hover:-translate-y-1.5 hover:shadow-2xl hover:shadow-brand-900/10"
          >
            <div class="flex items-center justify-between">
              <h2 class="font-display text-lg font-bold tracking-tight text-brand-900">{area.name}</h2>
              {area.featured && (
                <span class="inline-block rounded-full bg-brand-100 px-2.5 py-0.5 text-[11px] font-semibold text-brand-700">
                  Featured
                </span>
              )}
            </div>
            <p class="mt-1 text-sm text-stone-500">{area.county}</p>
            <div class="mt-3 flex items-center gap-1.5 text-sm text-stone-600">
              <Icon name="lucide:building-2" class="size-4 text-stone-400" />
              <span>Industrial & commercial</span>
            </div>
            <p class="mt-3 line-clamp-2 text-sm leading-relaxed text-stone-500">
              {area.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-brand-950 py-16 lg:py-20">
    <div class="absolute inset-0 bg-gradient-to-t from-brand-950 via-brand-950/90 to-brand-900"></div>
    <div class="blueprint-grid-dark absolute inset-0 opacity-70"></div>
    <div class="absolute -bottom-24 left-1/2 h-80 w-[42rem] -translate-x-1/2 rounded-full bg-accent-500/15 blur-[120px]"></div>
    <div class="relative mx-auto max-w-7xl px-5 lg:px-8">
      <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
        <div>
          <h2 class="font-display text-3xl font-bold tracking-tight text-white">Need Fabrication in Your Area?</h2>
          <p class="mt-2 text-brand-200">
            We deliver across Abu Dhabi and the UAE. Contact us for delivery availability to your project location.
          </p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-4">
          <a
            href={business.phoneHref}
            class="btn-shine group inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-accent-500 to-brand-500 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-accent-600/30 transition-all hover:-translate-y-0.5"
          >
            <Icon name="lucide:phone" class="size-5" />
            {business.phone}
          </a>
          <a
            href={contactUrl()}
            class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 px-6 py-3.5 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:border-white/30 hover:bg-white/10"
          >
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
